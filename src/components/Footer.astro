---
import { site } from '../data/site';
import { services } from '../data/services';
import { locations } from '../data/locations';
---

<footer class="bg-neutral-900 text-white pt-24 pb-12">
  <div class="container mx-auto px-4 md:px-8 max-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16 border-b border-neutral-700 pb-16">
      <!-- Column 1: Brand -->
      <div class="space-y-6">
        <a href="/" class="block group transition-transform hover:scale-105 origin-left">
          <img src="/images/logo.png" alt={site.name} class="h-10 md:h-12 w-auto" />
        </a>
        <p class="text-neutral-400 text-sm leading-relaxed max-w-xs">
          Professional arborist-led tree services across South Carolina. Specializing in safe removal, emergency response, and proactive property maintenance.
        </p>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h3 class="text-lg font-semibold mb-6">Our Services</h3>
        <ul class="space-y-3">
          {services.slice(0, 5).map((service) => (
            <li>
              <a href={`/services/${service.slug}/`} class="text-neutral-300 hover:text-primary-400 text-sm transition-colors">
                {service.name}
              </a>
            </li>
          ))}
          <li>
            <a href="/services/" class="text-primary-500 hover:text-primary-400 text-sm font-medium transition-colors">
              View All Services &rarr;
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Service Areas -->
      <div>
        <h3 class="text-lg font-semibold mb-6">Service Areas</h3>
        <ul class="space-y-3">
          {locations.slice(0, 5).map((loc) => (
            <li>
              <a href={`/locations/${loc.slug}/`} class="text-neutral-300 hover:text-primary-400 text-sm transition-colors">
                {loc.name}, SC
              </a>
            </li>
          ))}
          <li>
            <a href="/locations/" class="text-primary-500 hover:text-primary-400 text-sm font-medium transition-colors">
              View All Areas &rarr;
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="text-lg font-semibold mb-6">Get in Touch</h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-3 group text-neutral-300 hover:text-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500 shrink-0 mt-1"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href={`tel:${site.phone}`} class="text-sm">
              {site.phone}
            </a>
          </li>
          <li class="flex items-start space-x-3 group text-neutral-300 hover:text-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500 shrink-0 mt-1"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
            <a href={`mailto:${site.email}`} class="text-sm break-all">
              {site.email}
            </a>
          </li>
          <li class="flex items-start space-x-3 group text-neutral-300">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500 shrink-0 mt-1"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-sm">
              {site.address.street}<br />
              {site.address.city}, {site.address.state} {site.address.zip}
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col md:flex-row justify-between items-center text-xs text-neutral-500 gap-4">
      <p>&copy; {new Date().getFullYear()} {site.legalName}. All rights reserved.</p>
      <div class="flex space-x-6">
        <a href="/privacy/" class="hover:text-primary-400 transition-colors underline underline-offset-4 decoration-neutral-700">Privacy Policy</a>
        <a href="/terms/" class="hover:text-primary-400 transition-colors underline underline-offset-4 decoration-neutral-700">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
