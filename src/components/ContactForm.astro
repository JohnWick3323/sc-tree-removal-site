---
import { site } from '../data/site';
import { Send, BadgeCheck } from 'lucide-react';

interface Props {
  title?: string;
  subtitle?: string;
  isDark?: boolean;
}

const { 
  title = "Request a Free Estimate", 
  subtitle = "Our experts typically respond within 4 hours.",
  isDark = false 
} = Astro.props;

const success = Astro.url.searchParams.get('success') === 'true';
---

<div class={`p-8 md:p-10 rounded-3xl border ${isDark ? 'bg-neutral-900 border-neutral-800 text-white' : 'bg-white border-neutral-200 shadow-2xl'} relative overflow-hidden h-full`}>
  <div class="absolute top-0 left-0 w-full h-2 bg-primary-600"></div>
  
  <div class="mb-8">
    <h3 class={`text-2xl font-bold flex items-center gap-3 ${isDark ? 'text-white' : 'text-neutral-900'}`}>
      <Send size={24} className="text-primary-600" />
      {title}
    </h3>
    <p class={`text-sm mt-2 ${isDark ? 'text-neutral-400' : 'text-neutral-500'}`}>{subtitle}</p>
  </div>

  {success && (
    <div class="mb-8 p-6 bg-green-50 border border-green-200 text-green-700 rounded-2xl flex items-center gap-3 animate-bounce">
      <BadgeCheck size={24} />
      <p class="font-bold text-sm">Thank you! Your request has been sent successfully.</p>
    </div>
  )}

  <form action="/api/send-email/" method="POST" class="space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label for="name" class={`block text-[10px] font-black uppercase tracking-widest mb-2 ${isDark ? 'text-neutral-400' : 'text-neutral-700'}`}>Full Name</label>
        <input type="text" id="name" name="name" placeholder="Your Name" class={`w-full border p-4 rounded-xl focus:ring-2 focus:ring-primary-600 outline-none transition-all ${isDark ? 'bg-neutral-800 border-neutral-700 text-white placeholder:text-neutral-600' : 'bg-neutral-50 border-neutral-200 text-neutral-900'}`} required />
      </div>
      <div>
        <label for="phone" class={`block text-[10px] font-black uppercase tracking-widest mb-2 ${isDark ? 'text-neutral-400' : 'text-neutral-700'}`}>Phone Number</label>
        <input type="tel" id="phone" name="phone" placeholder="(XXX) XXX-XXXX" class={`w-full border p-4 rounded-xl focus:ring-2 focus:ring-primary-600 outline-none transition-all ${isDark ? 'bg-neutral-800 border-neutral-700 text-white placeholder:text-neutral-600' : 'bg-neutral-50 border-neutral-200 text-neutral-900'}`} required />
      </div>
    </div>

    <div>
      <label for="email" class={`block text-[10px] font-black uppercase tracking-widest mb-2 ${isDark ? 'text-neutral-400' : 'text-neutral-700'}`}>Email Address</label>
      <input type="email" id="email" name="email" placeholder="email@example.com" class={`w-full border p-4 rounded-xl focus:ring-2 focus:ring-primary-600 outline-none transition-all ${isDark ? 'bg-neutral-800 border-neutral-700 text-white placeholder:text-neutral-600' : 'bg-neutral-50 border-neutral-200 text-neutral-900'}`} required />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label for="service" class={`block text-[10px] font-black uppercase tracking-widest mb-2 ${isDark ? 'text-neutral-400' : 'text-neutral-700'}`}>Service Needed</label>
        <select id="service" name="service" class={`w-full border p-4 rounded-xl focus:ring-2 focus:ring-primary-600 outline-none transition-all appearance-none ${isDark ? 'bg-neutral-800 border-neutral-700 text-white' : 'bg-neutral-50 border-neutral-200 text-neutral-900'}`}>
          <option>Tree Removal</option>
          <option>Emergency Storm Response</option>
          <option>Trimming & Pruning</option>
          <option>Stump Grinding</option>
          <option>Land Clearing</option>
          <option>Other</option>
        </select>
      </div>
      <div>
        <label for="location" class={`block text-[10px] font-black uppercase tracking-widest mb-2 ${isDark ? 'text-neutral-400' : 'text-neutral-700'}`}>City</label>
        <input type="text" id="location" name="location" placeholder="e.g. Charleston, SC" class={`w-full border p-4 rounded-xl focus:ring-2 focus:ring-primary-600 outline-none transition-all ${isDark ? 'bg-neutral-800 border-neutral-700 text-white placeholder:text-neutral-600' : 'bg-neutral-50 border-neutral-200 text-neutral-900'}`} required />
      </div>
    </div>

    <div>
      <label for="message" class={`block text-[10px] font-black uppercase tracking-widest mb-2 ${isDark ? 'text-neutral-400' : 'text-neutral-700'}`}>Project Details</label>
      <textarea id="message" name="message" rows="3" placeholder="Briefly describe your project..." class={`w-full border p-4 rounded-xl focus:ring-2 focus:ring-primary-600 outline-none transition-all resize-none ${isDark ? 'bg-neutral-800 border-neutral-700 text-white placeholder:text-neutral-600' : 'bg-neutral-50 border-neutral-200 text-neutral-900'}`} required></textarea>
    </div>

    <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-5 rounded-xl text-lg shadow-xl hover:shadow-2xl transition-all flex items-center justify-center gap-3">
      <Send size={20} />
      Send Request
    </button>
    <p class={`text-[10px] text-center mt-4 uppercase tracking-widest font-bold ${isDark ? 'text-neutral-600' : 'text-neutral-400'}`}>
      Licensed • Insured • Guaranteed
    </p>
  </form>
</div>
