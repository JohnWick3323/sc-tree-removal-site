---
interface Props {
  title?: string;
  subtitle?: string;
  isDark?: boolean;
}

const { 
  isDark = false 
} = Astro.props;
---

<div class={`rounded-3xl border overflow-hidden ${isDark ? 'bg-neutral-900 border-neutral-800' : 'bg-white border-neutral-100 shadow-2xl'}`}>
