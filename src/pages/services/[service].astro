---
import { services } from '../../data/services';
import { locations } from '../../data/locations';
import { combinations } from '../../data/combinations';
import { AnimatedIcon } from '../../components/AnimatedIcon';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Phone, CheckCircle, Clock, ShieldCheck, MapPin, Star, HelpCircle, ArrowRight } from 'lucide-react';

export async function getStaticPaths() {
  return services.map(service => ({
    params: { service: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;

// Get location variants for this service
const serviceLocations = locations.slice(0, 12);

// Breadcrumbs
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services' },
  { name: service.name, href: `/services/${service.slug}` }
];

// Related services
const relatedServices = services.filter(s => s.slug !== service.slug).slice(0, 3);

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": service.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<BaseLayout 
  title={`${service.name} | Expert Tree Services in South Carolina`}
  description={service.metaDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-24 md:pt-48 md:pb-36 bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-primary-900/80 backdrop-blur-sm z-10"></div>
      <img src={service.image || `/images/services/${service.slug}.webp`} alt={service.name} class="w-full h-full object-cover" />
    </div>

    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-20 text-center text-white">
      <nav class="flex justify-center mb-8">
        <ol class="flex items-center gap-2 text-sm font-medium text-primary-200">
          {breadcrumbs.map((bc, idx) => (
            <li class="flex items-center gap-2">
              <a href={bc.href} class="hover:text-white transition-colors">{bc.name}</a>
              {idx < breadcrumbs.length - 1 && <span class="text-primary-500">/</span>}
            </li>
          ))}
        </ol>
      </nav>
      <h1 class="text-4xl md:text-6xl font-bold font-heading mb-8 leading-tight max-w-4xl mx-auto">
        {service.heroHeading}
      </h1>
      <p class="text-xl text-primary-50 max-w-2xl mx-auto leading-relaxed mb-12">
        {service.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1">
          Request a Free Quote
        </a>
        <a href="tel:(843) 241-0787" class="bg-white text-primary-700 px-8 py-4 rounded-md font-bold text-lg transition-all flex items-center justify-center gap-2">
          <AnimatedIcon client:load icon={Phone} size={20} animation="shake" />
          (843) 241-0787
        </a>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <div class="lg:col-span-2 prose prose-lg prose-primary max-w-none">
          <h2 class="text-3xl font-bold text-neutral-900">Professional {service.name} Overview</h2>
          <p>{service.longContent.intro}</p>
          
          <div class="my-12 p-8 bg-neutral-50 rounded-3xl border border-neutral-100 italic">
             <p class="mb-0 text-neutral-700">
               <strong>Internal Note:</strong> Looking for this service in a specific area? We provide arborist-led 
               <a href={`/services/${service.slug}/columbia/`} class="text-primary-600 font-bold decoration-primary-200 underline-offset-4">{service.name} in Columbia</a>, 
               <a href={`/services/${service.slug}/charleston/`} class="text-primary-600 font-bold decoration-primary-200 underline-offset-4">Charleston</a>, 
               and across the entire state.
             </p>
          </div>

          <h2 class="text-3xl font-bold text-neutral-900">Our {service.name} Methodology</h2>
          <p>{service.longContent.methodology}</p>

          <h2 class="text-3xl font-bold text-neutral-900">South Carolina Specific Arborist Advice</h2>
          <p>{service.longContent.localAdvice}</p>

          <h2 class="text-3xl font-bold text-neutral-900">Seasonal Considerations for {service.name}</h2>
          <p>{service.longContent.seasonalConsiderations}</p>

          <h2 class="text-3xl font-bold text-neutral-900">Common Problems We Solve</h2>
          <p>{service.longContent.homeownerProblems}</p>
        </div>

        <div class="space-y-12">
          <!-- Features Sidebar -->
          <div class="bg-neutral-50 p-8 rounded-3xl border border-neutral-100">
            <h3 class="text-xl font-bold mb-6 text-neutral-900">Key Service Features</h3>
            <ul class="space-y-4">
              {service.features.map(feature => (
                <li class="flex items-start gap-3">
                  <CheckCircle size={18} className="text-primary-600 shrink-0 mt-1" />
                  <span class="text-neutral-700 font-medium">{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Mid-page CTA -->
          <div class="bg-primary-900 p-8 rounded-3xl text-white">
            <h3 class="text-2xl font-bold mb-4">Get a Professional Assessment</h3>
            <p class="text-primary-100 mb-8 leading-relaxed">Our certified arborists are ready to evaluate your {service.name.toLowerCase()} needs today.</p>
            <a href="/contact/" class="block w-full bg-primary-500 text-center py-4 rounded-xl font-bold hover:bg-primary-400 transition-colors">
              Schedule Now
            </a>
          </div>

          <!-- Quick Info Cards -->
          <div class="grid grid-cols-1 gap-4">
            <div class="bg-white p-6 rounded-2xl border border-neutral-200 shadow-sm flex items-center gap-4">
              <ShieldCheck size={32} className="text-primary-600" />
              <div>
                <p class="font-bold text-neutral-900">Fully Insured</p>
                <p class="text-xs text-neutral-500">Protection for every project</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-2xl border border-neutral-200 shadow-sm flex items-center gap-4">
              <Clock size={32} className="text-primary-600" />
              <div>
                <p class="font-bold text-neutral-900">24/7 Availability</p>
                <p class="text-xs text-neutral-500">Emergency storm response</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Location Variants Section -->
  <section class="py-24 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold font-heading text-neutral-900 mb-6">Local {service.name} Experts Near You</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Providing specialized arborist-led services across South Carolina from the Lowcountry to the Upstate.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {serviceLocations.map(loc => (
          <a href={`/services/${service.slug}/${loc.slug}/`} class="group bg-white p-6 rounded-2xl shadow-sm border border-neutral-200 hover:border-primary-500 hover:shadow-xl transition-all duration-300">
            <div class="flex items-center gap-2 mb-3">
              <MapPin size={18} className="text-primary-600" />
              <h3 class="font-bold group-hover:text-primary-700 transition-colors">{service.name} in {loc.name}</h3>
            </div>
            <p class="text-neutral-500 text-xs line-clamp-2">
              Serving {loc.county} and surrounding areas.
            </p>
          </a>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/locations/" class="text-primary-600 font-bold hover:underline underline-offset-4">View All Service Locations &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Related Services Section -->
  <section class="py-24 bg-white border-t border-neutral-100">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl text-center">
      <h2 class="text-3xl font-bold font-heading text-neutral-900 mb-12">Related arborist Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
        {relatedServices.map(rs => (
          <a href={`/services/${rs.slug}/`} class="group p-8 rounded-3xl bg-neutral-50 border border-neutral-100 hover:bg-white hover:shadow-2xl hover:border-primary-200 transition-all duration-300">
            <h3 class="text-xl font-bold mb-4 group-hover:text-primary-600 transition-colors">{rs.name}</h3>
            <p class="text-neutral-600 text-sm mb-6 leading-relaxed line-clamp-3">{rs.description}</p>
            <span class="text-primary-600 font-bold flex items-center gap-2 text-sm">
              Service Details <ArrowRight size={16} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-24 bg-neutral-900 text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <div class="text-center mb-16">
        <div class="bg-primary-600/20 p-4 rounded-full text-primary-400 inline-flex mb-6 border border-primary-500/30">
          <HelpCircle size={32} />
        </div>
        <h2 class="text-3xl md:text-4xl font-bold font-heading mb-6">Frequently Asked Questions</h2>
        <p class="text-lg text-neutral-400">{service.name}-specific arborist insights for South Carolina property owners.</p>
      </div>

      <div class="space-y-6">
        {service.faqs.map((faq) => (
          <div class="bg-neutral-800 rounded-2xl border border-neutral-700 overflow-hidden shadow-sm">
            <div class="p-8">
              <h3 class="text-xl font-bold font-heading text-white mb-4 flex items-start gap-3 leading-tight">
                <span class="text-primary-500 mt-1 shrink-0">Q.</span>
                {faq.question}
              </h3>
              <p class="text-neutral-400 leading-relaxed flex items-start gap-3">
                <span class="text-primary-500 mt-1 font-bold shrink-0">A.</span>
                {faq.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-24 bg-primary-600 text-white relative overflow-hidden">
    <div class="container mx-auto px-4 md:px-8 max-w-5xl relative z-10 text-center">
      <h2 class="text-3xl md:text-5xl font-bold font-heading mb-8 leading-tight">Ready to Get Started with Your {service.name}?</h2>
      <p class="text-xl text-primary-50 mb-12 leading-relaxed max-w-3xl mx-auto">
        Our expert arborist team is ready to assess your property anywhere in South Carolina. We provide clear, written estimates and guarantee zero-impact cleanup on every job.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="bg-white text-primary-700 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-50 transition-all shadow-xl">
          Free Estimate
        </a>
        <a href="tel:(843) 241-0787" class="bg-primary-700 text-white border border-primary-500 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-800 transition-all flex items-center justify-center gap-3">
          <Phone size={24} />
          (843) 241-0787
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
