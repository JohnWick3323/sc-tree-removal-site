---
import { site } from "../../data/site";
import { services } from '../../data/services';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import { Phone, CheckCircle, ShieldCheck, HardHat, MapPin, Leaf, ChevronDown, Award, Users, AlertTriangle } from 'lucide-react';

const pillars = services.filter(s => s.isPillar);
const supportingByCategory = services.filter(s => !s.isPillar).reduce((acc, s) => {
  if (!acc[s.category]) acc[s.category] = [];
  acc[s.category].push(s);
  return acc;
}, {} as Record<string, typeof services>);

const breadcrumbs = [{ name: 'Home', href: '/' }, { name: 'Services', href: '/services/' }];
const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": breadcrumbs.map((bc, idx) => ({ "@type": "ListItem", "position": idx + 1, "name": bc.name, "item": `${site.url}${bc.href}` })) };
const itemListSchema = { "@context": "https://schema.org", "@type": "ItemList", "name": "Tree Removal Services in South Carolina", "itemListElement": services.map((s, idx) => ({ "@type": "ListItem", "position": idx + 1, "url": `${site.url}/services/${s.slug}/`, "name": s.name })) };
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{ "@type": "Question", "name": "How much does tree removal cost in South Carolina?", "acceptedAnswer": { "@type": "Answer", "text": "Tree removal costs in South Carolina vary depending on several factors — including the size of the tree, its location, how close it is to structures, and the method required for safe removal. We never quote a fixed price without seeing the job first —but we always provide a free, transparent estimate so you know exactly what to expect before any work begins." } }, { "@type": "Question", "name": "Do you offer free estimates?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — South Carolina Tree Removal Experts provides free on-site estimates on every job, with no obligation and no pressure. Simply call (888) 643-4199 and we will schedule a visit at a time that works for you." } }, { "@type": "Question", "name": "Are you licensed and insured in South Carolina?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we are fully licensed and insured in the state of South Carolina on every job we perform. We carry complete liability coverage and workers' compensation so you are fully protected throughout the entire removal process." } }, { "@type": "Question", "name": "How quickly can you respond to a tree emergency in South Carolina?", "acceptedAnswer": { "@type": "Answer", "text": "South Carolina Tree Removal Experts operates 24 hours a day, 7 days a week for emergency tree removal situations. We prioritize emergency calls and dispatch a crew as quickly as possible — whether the emergency is in Charleston, Greenville, Myrtle Beach, Columbia, or anywhere else across the state." } }, { "@type": "Question", "name": "Do you work with insurance claims for storm damage?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we understand that storm damage tree removal often involves a homeowner's insurance claim. We document the removal process thoroughly and can provide the paperwork and photos your insurance company may require to support your claim." } }, { "@type": "Question", "name": "What size trees can you remove?", "acceptedAnswer": { "@type": "Answer", "text": "South Carolina Tree Removal Experts removes trees of every size — from small ornamental trees in residential yards to massive Loblolly Pines, Water Oaks, and Southern Live Oaks on large properties. For oversized or hard-to-access trees, we use our crane-assisted removal equipment to handle the job safely and without damaging your property." } }, { "@type": "Question", "name": "Do You Serve My Area in South Carolina?", "acceptedAnswer": { "@type": "Answer", "text": "We serve all of South Carolina — including Columbia, Charleston, Greenville, Myrtle Beach, Spartanburg, Rock Hill, Summerville, Florence, Hilton Head, Anderson, Aiken, Lexington, and every city and town in between. If you are in South Carolina, we can help — call (888) 643-4199 to confirm service availability in your area." } }] };
---

<BaseLayout title="Tree Removal in South Carolina | South Carolina Tree Removal Experts" description="Need professional tree removal in South Carolina? South Carolina Tree Removal Experts has 38 years of experience. Licensed & insured. Free quotes. Call (888) 643-4199.">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header slot="header" />

  <section class="relative pt-32 pb-24 md:pt-48 md:pb-36 bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0"><div class="absolute inset-0 bg-primary-900/85 backdrop-blur-sm z-10"></div><img src="/images/optimized/hero-services.webp" alt="South Carolina Tree Removal Experts at Work" class="w-full h-full object-cover" /></div>
    <div class="container mx-auto px-4 md:px-8 max-w-5xl relative z-20 text-center text-white">
      <nav class="flex justify-center mb-8"><ol class="flex items-center gap-2 text-sm font-medium text-primary-200">{breadcrumbs.map((bc, idx) => (<li class="flex items-center gap-2"><a href={bc.href} class="hover:text-white transition-colors">{bc.name}</a>{idx < breadcrumbs.length - 1 && <span class="text-primary-500">/</span>}</li>))}</ol></nav>
      <h1 class="text-4xl md:text-6xl font-bold font-heading mb-8 leading-tight">South Carolina's Most Trusted Tree Removal Experts &mdash; <span class="text-primary-400">Serving the Entire State for 38 Years</span></h1>
      <p class="text-xl text-primary-50 max-w-3xl mx-auto leading-relaxed mb-12">Licensed. Insured. Local. Available 24/7 for Emergency Tree Removal Across All of South Carolina.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-12 max-w-4xl mx-auto">
        <div class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-xl px-4 py-3 text-center"><span class="block text-xs font-bold text-primary-300">38 Years</span><span class="block text-xs text-white/70">Experience</span></div>
        <div class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-xl px-4 py-3 text-center"><span class="block text-xs font-bold text-primary-300">Licensed</span><span class="block text-xs text-white/70">&amp; Insured</span></div>
        <div class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-xl px-4 py-3 text-center"><span class="block text-xs font-bold text-primary-300">Free</span><span class="block text-xs text-white/70">Estimates</span></div>
        <div class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-xl px-4 py-3 text-center"><span class="block text-xs font-bold text-primary-300">24/7</span><span class="block text-xs text-white/70">Emergency Response</span></div>
        <div class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-xl px-4 py-3 text-center col-span-2 md:col-span-1"><span class="block text-xs font-bold text-primary-300">Serving</span><span class="block text-xs text-white/70">All of SC</span></div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center"><a href="/contact/" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1">Get Your Free Estimate Today</a><a href={`tel:${site.phone}`} class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-md font-bold text-lg transition-all text-center flex items-center justify-center gap-3"><Phone size={20} /> {site.phone}</a></div>
    </div>
  </section>

  <section class="py-24 bg-white"><div class="container mx-auto px-4 md:px-8 max-w-5xl">
    <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-10 text-center">Professional Tree Removal Services Across All of South Carolina</h2>
    <p class="text-lg text-neutral-600 mb-6 leading-relaxed">South Carolina Tree Removal Experts has been serving homeowners, businesses, and property managers across the Palmetto State for over 38 years. We are a licensed and insured tree removal company built on a reputation for safe, efficient, and professional work on every single job.</p>
    <p class="text-lg text-neutral-600 mb-6 leading-relaxed">From Columbia and Charleston to Greenville, Myrtle Beach, and everywhere in between, our experienced crews are ready to handle any tree removal challenge. Whether it is a single hazardous tree in your backyard or a full commercial land clearing project, we have the equipment, the expertise, and the experience to get it done right.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-16">
      <div><h3 class="text-2xl font-bold font-heading text-neutral-900 mb-4">What We Do</h3><p class="text-neutral-600 mb-4 leading-relaxed">We specialize in tree removal, emergency tree response, land and lot clearing, brush clearing, debris removal, and forestry mulching. Every job — no matter the size — is handled by trained, local crews who know South Carolina's tree landscape better than anyone.</p></div>
      <div><h3 class="text-2xl font-bold font-heading text-neutral-900 mb-4">Who We Serve</h3><p class="text-neutral-600 mb-4 leading-relaxed">We work with South Carolina homeowners dealing with dead, damaged, or dangerous trees on their property. We also serve property managers, business owners, developers, and contractors who need reliable, large-scale tree removal and land clearing services.</p></div>
    </div>

    <div class="mt-16 bg-neutral-50 rounded-2xl border border-neutral-100 p-8 md:p-10">
      <h3 class="text-2xl font-bold font-heading text-neutral-900 mb-6">Our Services at a Glance</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {pillars.map(pillar => {
          const siblings = supportingByCategory[pillar.category] || [];
          return (
            <a href={`/services/${pillar.slug}/`} class="flex items-start gap-4 p-4 bg-white rounded-xl border border-neutral-100 hover:border-primary-500 hover:shadow-md transition-all group">
              <div class="bg-primary-50 p-3 rounded-lg text-primary-600 shrink-0">{pillar.category === 'tree-removal' && <Leaf size={22} />}{pillar.category === 'emergency' && <AlertTriangle size={22} />}{pillar.category === 'land-clearing' && <HardHat size={22} />}</div>
              <div>
                <span class="font-bold text-neutral-900 group-hover:text-primary-700 transition-colors">{pillar.name}</span>
                <p class="text-sm text-neutral-500 mt-1">{pillar.description}</p>
                <div class="mt-2 flex flex-wrap gap-2">
                  {siblings.sort((a,b)=>a.clusterOrder-b.clusterOrder).map((s: any) => <span class="text-xs bg-primary-50 text-primary-700 px-2 py-1 rounded-full">{s.name}</span>)}
                </div>
              </div>
            </a>
          )})}
      </div>
      <div class="mt-8 pt-6 border-t border-neutral-200">
        <ul class="space-y-3 text-neutral-600 text-sm">
          <li><strong>Land &amp; Lot Clearing</strong> &mdash; Forestry mulching, brush clearing, and debris removal</li>
          <li><strong>Emergency Tree Removal</strong> &mdash; Storm response, fallen tree removal, and tree-on-structure response</li>
        </ul>
      </div>
    </div>
    
    <div class="mt-20">
      <h2 class="text-3xl md:text-4xl font-bold font-heading text-neutral-900 mb-6">Why South Carolina Homeowners Have Trusted Us for 38 Years</h2>
      <div class="prose prose-lg prose-primary max-w-none text-neutral-600 mb-16">
        <p>With nearly four decades of hands-on experience, we have built a track record that speaks for itself.</p>
        <p>We are not a call center or a national franchise — we are a local South Carolina tree removal company that shows up, does the work safely, and leaves your property clean.</p>
        <p>Our crews understand the unique challenges posed by South Carolina's climate — from hurricane season along the Grand Strand to ice storms in the Upstate.</p>
        <p>That local knowledge, combined with 38 years of experience, is what sets South Carolina Tree Removal Experts apart from every other tree service in the state.</p>
      </div>

      <h2 class="text-3xl md:text-4xl font-bold font-heading text-neutral-900 mb-6">What to Expect When You Call Us for Tree Removal</h2>
      <div class="prose prose-lg prose-primary max-w-none text-neutral-600 mb-10">
        <p>When you call South Carolina Tree Removal Experts, we move quickly. We schedule a free on-site assessment, give you a transparent quote with no hidden fees, and get the job scheduled at a time that works for you.</p>
        <p>Our crew arrives on time, works efficiently, and cleans up completely before leaving your property.</p>
        <p>From your first call to the final walkthrough — every step is handled with professionalism and care.</p>
      </div>
      <div class="bg-primary-50 p-6 rounded-xl border border-primary-100 flex items-center gap-4">
        <div class="bg-primary-600 text-white p-3 rounded-full shrink-0"><Phone size={24} /></div>
        <p class="text-xl font-bold text-primary-900 m-0">Call <a href="tel:888-643-4199" class="text-primary-700 hover:text-primary-800">(888) 643-4199</a> for a Free Tree Removal Quote — Serving All of South Carolina</p>
      </div>
    </div>
  </div></section>

  <!-- FAQ Section (same as current) -->
  <section class="py-24 bg-white border-t border-neutral-100"><div class="container mx-auto px-4 md:px-8 max-w-4xl"><h2 class="text-4xl font-bold font-heading text-neutral-900 mb-16 text-center">Frequently Asked Questions About Tree Removal in South Carolina</h2><div class="space-y-4">{[
    { q: 'How much does tree removal cost in South Carolina?', a: 'Tree removal costs in South Carolina vary depending on several factors — including the size of the tree, its location, how close it is to structures, and the method required for safe removal. We never quote a fixed price without seeing the job first —but we always provide a free, transparent estimate so you know exactly what to expect before any work begins.' },
    { q: 'Do you offer free estimates?', a: 'Yes — South Carolina Tree Removal Experts provides free on-site estimates on every job, with no obligation and no pressure. Simply call (888) 643-4199 and we will schedule a visit at a time that works for you.' },
    { q: 'Are you licensed and insured in South Carolina?', a: "Yes — we are fully licensed and insured in the state of South Carolina on every job we perform. We carry complete liability coverage and workers' compensation so you are fully protected throughout the entire removal process." },
    { q: 'How quickly can you respond to a tree emergency in South Carolina?', a: 'South Carolina Tree Removal Experts operates 24 hours a day, 7 days a week for emergency tree removal situations. We prioritize emergency calls and dispatch a crew as quickly as possible — whether the emergency is in Charleston, Greenville, Myrtle Beach, Columbia, or anywhere else across the state.' },
    { q: 'Do you work with insurance claims for storm damage?', a: "Yes — we understand that storm damage tree removal often involves a homeowner's insurance claim. We document the removal process thoroughly and can provide the paperwork and photos your insurance company may require to support your claim." },
    { q: 'What size trees can you remove?', a: 'South Carolina Tree Removal Experts removes trees of every size — from small ornamental trees in residential yards to massive Loblolly Pines, Water Oaks, and Southern Live Oaks on large properties. For oversized or hard-to-access trees, we use our crane-assisted removal equipment to handle the job safely and without damaging your property.' },
    { q: 'Do You Serve My Area in South Carolina?', a: 'We serve all of South Carolina — including Columbia, Charleston, Greenville, Myrtle Beach, Spartanburg, Rock Hill, Summerville, Florence, Hilton Head, Anderson, Aiken, Lexington, and every city and town in between. If you are in South Carolina, we can help — call (888) 643-4199 to confirm service availability in your area.' }
  ].map(faq => (<details class="group bg-neutral-50 rounded-2xl border border-neutral-200 [&_summary::-webkit-details-marker]:hidden"><summary class="flex cursor-pointer items-center justify-between p-6 md:p-8 text-neutral-900 font-bold text-lg">{faq.q}<span class="transition duration-300 group-open:-rotate-180 text-primary-600 bg-white p-2 rounded-full shadow-sm flex-shrink-0 ml-4"><ChevronDown size={22} /></span></summary><div class="px-6 pb-6 md:px-8 md:pb-8 text-neutral-600 leading-relaxed">{faq.a}</div></details>))}</div><div class="mt-12 bg-primary-50 rounded-2xl border border-primary-100 p-6 text-center"><p class="font-bold text-neutral-900 text-lg">📞 Still Have Questions? Call South Carolina Tree Removal Experts at (888) 643-4199 — We Are Happy to Help.</p></div></div></section>

  <section class="py-24 bg-primary-600 relative overflow-hidden"><div class="absolute inset-0 bg-neutral-900/10 z-0"></div><div class="absolute bottom-0 left-0 w-96 h-96 bg-primary-500 rounded-full blur-3xl opacity-30 translate-y-1/2 -translate-x-1/2"></div><div class="container mx-auto px-4 md:px-8 max-w-4xl relative z-10 text-center"><h2 class="text-3xl md:text-5xl font-bold font-heading text-white mb-8 leading-tight">Need a Tree Removed in South Carolina? We Are Ready.</h2><p class="text-lg text-primary-50 mb-10 max-w-2xl mx-auto leading-relaxed">When a tree becomes a problem — whether it is dead, damaged, dangerous, or simply in the wrong place — South Carolina Tree Removal Experts is the team to call. We have been serving South Carolina homeowners, businesses, and property managers for over 38 years — and we are ready to help you today.</p><div class="flex flex-col sm:flex-row gap-4 justify-center mb-12"><a href={`tel:${site.phone}`} class="bg-white text-primary-700 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-50 transition-all shadow-xl flex items-center justify-center gap-3"><Phone size={24} /> Call (888) 643-4199 for a Free Quote</a><a href="/contact/" class="bg-primary-800 text-white border border-primary-500 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-900 transition-all text-center">Request a Free Estimate Online</a></div><div class="bg-primary-700/50 backdrop-blur-sm border border-primary-500/40 rounded-2xl p-8 mb-8"><p class="font-bold text-white text-xl mb-3">&#128680; Dealing With a Tree Emergency Right Now?</p><p class="text-primary-100 mb-4">Do not wait &mdash; call us immediately.</p><a href={`tel:${site.phone}`} class="inline-flex items-center justify-center gap-2 bg-white text-primary-700 px-8 py-4 rounded-md font-bold text-lg hover:bg-primary-50 transition-all"><Phone size={20} /> 24/7 Emergency &mdash; Call (888) 643-4199 Now</a><p class="text-primary-200 text-sm mt-3">We serve all of South Carolina around the clock.</p></div><p class="text-white font-bold text-lg mb-2">South Carolina Tree Removal Experts</p><p class="text-primary-200 text-sm mb-4">Licensed, Insured, and Proud to Serve South Carolina for Over 38 Years.</p><p class="text-primary-300 text-xs">South Carolina Tree Removal Experts &mdash; (888) 643-4199</p></div></section>

  <Footer slot="footer" />
</BaseLayout>
