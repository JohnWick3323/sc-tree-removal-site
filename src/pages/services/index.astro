---
import { site } from "../../data/site";
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Phone, ChevronDown, ShieldCheck, Leaf, AlertTriangle, HardHat, Users } from 'lucide-react';

const breadcrumbs = [{ name: 'Home', href: '/' }, { name: 'Services', href: '/services/' }];
const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": breadcrumbs.map((bc, idx) => ({ "@type": "ListItem", "position": idx + 1, "name": bc.name, "item": `${site.url}${bc.href}` })) };
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Tree Removal Services in South Carolina",
  "itemListElement": [
    "tree-removal",
    "dead-tree-removal",
    "hazardous-tree-removal",
    "crane-assisted-tree-removal",
    "tree-cutting-felling",
    "emergency-tree-removal",
    "emergency-storm-response",
    "fallen-tree-removal",
    "tree-on-house-removal",
    "tree-on-car-removal",
    "land-clearing",
    "forestry-mulching",
    "brush-clearing",
    "debris-removal"
  ].map((slug, idx) => ({ "@type": "ListItem", "position": idx + 1, "url": `${site.url}/services/${slug}/` }))
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    ["How much does tree removal cost in South Carolina?", "Tree removal costs in South Carolina vary depending on several factors, including the size of the tree, its location, how close it is to structures, and the method required for safe removal. We never quote a fixed price without seeing the job first, but we always provide a free, transparent estimate so you know exactly what to expect before any work begins."],
    ["Do you offer free estimates?", "Yes. South Carolina Tree Removal Experts provides free on-site estimates on every job, with no obligation and no pressure. Simply call (888) 643-4199 and we will schedule a visit at a time that works for you."],
    ["Are you licensed and insured in South Carolina?", "Yes. We are fully licensed and insured in the state of South Carolina on every job we perform. We carry complete liability coverage and workers' compensation so you are fully protected throughout the entire removal process."],
    ["How quickly can you respond to a tree emergency in South Carolina?", "South Carolina Tree Removal Experts operates 24 hours a day, 7 days a week for emergency tree removal situations. We prioritize emergency calls and dispatch a crew as quickly as possible whether the emergency is in Charleston, Greenville, Myrtle Beach, Columbia, or anywhere else across the state."],
    ["Do you work with insurance claims for storm damage?", "Yes. We understand that storm damage tree removal often involves a homeowner's insurance claim. We document the removal process thoroughly and can provide the paperwork and photos your insurance company may require to support your claim."],
    ["What size trees can you remove?", "South Carolina Tree Removal Experts removes trees of every size, from small ornamental trees in residential yards to massive Loblolly Pines, Water Oaks, and Southern Live Oaks on large properties. For oversized or hard-to-access trees, we use crane-assisted removal equipment to handle the job safely and without damaging your property."],
    ["Do you serve my area in South Carolina?", "We serve all of South Carolina, including Columbia, Charleston, Greenville, Myrtle Beach, Spartanburg, Rock Hill, Summerville, Florence, Hilton Head, Anderson, Aiken, Lexington, and every city and town in between."]
  ].map(([name, text]) => ({ "@type": "Question", name, "acceptedAnswer": { "@type": "Answer", text } }))
};
---

<BaseLayout title="Tree Removal in South Carolina | South Carolina Tree Removal Experts" description="Need professional tree removal in South Carolina? South Carolina Tree Removal Experts has 38 years of experience. Licensed & insured. Free quotes. Call (888) 643-4199.">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header slot="header" />

  <section class="relative pt-32 pb-24 md:pt-48 md:pb-36 bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0"><div class="absolute inset-0 bg-primary-900/85 backdrop-blur-sm z-10"></div><img src="/images/optimized/hero-services.webp" alt="South Carolina Tree Removal Experts at Work" class="w-full h-full object-cover" /></div>
    <div class="container mx-auto px-4 md:px-8 max-w-5xl relative z-20 text-center text-white">
      <nav class="flex justify-center mb-8"><ol class="flex items-center gap-2 text-sm font-medium text-primary-200">{breadcrumbs.map((bc, idx) => (<li class="flex items-center gap-2"><a href={bc.href} class="hover:text-white transition-colors">{bc.name}</a>{idx < breadcrumbs.length - 1 && <span class="text-primary-500">/</span>}</li>))}</ol></nav>
      <h1 class="text-4xl md:text-6xl font-bold font-heading mb-8 leading-tight">South Carolina's Most Trusted Tree Removal Experts - <span class="text-primary-400">Serving the Entire State for 38 Years</span></h1>
      <p class="text-xl text-primary-50 max-w-3xl mx-auto leading-relaxed mb-10">Licensed. Insured. Local. Available 24/7 for Emergency Tree Removal Across All of South Carolina.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-12 max-w-4xl mx-auto">
        {['38 Years of Experience','Licensed & Insured in SC','Free Estimates','24/7 Emergency Response','Serving All of South Carolina'].map(item => (
          <div class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-xl px-4 py-3 text-center text-xs font-bold text-primary-100">{item}</div>
        ))}
      </div>
      <div class="max-w-3xl mx-auto text-primary-50 text-lg leading-relaxed mb-10 space-y-4">
        <p>South Carolina Tree Removal Experts is the Palmetto State's most experienced tree removal company - trusted by homeowners, property managers, and businesses for over 38 years.</p>
        <p>Whether you have a dead tree threatening your roof, storm damage that cannot wait, or land that needs clearing, we are the team South Carolina calls.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center"><a href="/contact/" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1">Get Your Free Estimate Today</a><a href={`tel:${site.phone}`} class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-md font-bold text-lg transition-all text-center flex items-center justify-center gap-3"><Phone size={20} /> Call Now - {site.phone}</a></div>
      <div class="mt-12 rounded-2xl border border-primary-400/40 bg-primary-600/30 p-6 text-white">
        <p class="font-bold text-lg">Storm Damage? Tree on Your House or Car?</p>
        <p class="text-primary-50 mt-2">We respond fast - 24 hours a day, 7 days a week. <a href="/services/emergency-tree-removal/" class="font-bold underline">Emergency Tree Removal Available Statewide</a>.</p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-5xl">
      <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-10 text-center">Professional Tree Removal Services Across All of South Carolina</h2>
      <div class="prose prose-lg prose-primary max-w-none text-neutral-600">
        <p>South Carolina Tree Removal Experts has been serving homeowners, businesses, and property managers across the Palmetto State for over 38 years.</p>
        <p>We are a licensed and insured tree removal company - built on a reputation for safe, efficient, and professional work on every single job.</p>
        <p>From Columbia and Charleston to Greenville, Myrtle Beach, and everywhere in between, our experienced crews are ready to handle any tree removal challenge.</p>
        <p>Whether it is a single hazardous tree in your backyard or a full commercial land clearing project, we have the equipment, the expertise, and the experience to get it done right.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-16">
        <div><h3 class="text-2xl font-bold font-heading text-neutral-900 mb-4">What We Do</h3><p class="text-neutral-600 leading-relaxed">We specialize exclusively in tree removal, emergency tree response, land and lot clearing, and commercial tree services. Every job - no matter the size - is handled by trained, local crews who know South Carolina's tree landscape better than anyone.</p></div>
        <div><h3 class="text-2xl font-bold font-heading text-neutral-900 mb-4">Who We Serve</h3><p class="text-neutral-600 leading-relaxed">We work with South Carolina homeowners dealing with dead, damaged, or dangerous trees on their property. We also serve property managers, business owners, developers, and contractors who need reliable, large-scale tree removal and land clearing services.</p></div>
      </div>
      <div class="mt-16 rounded-2xl bg-neutral-50 border border-neutral-100 p-8">
        <h3 class="text-2xl font-bold font-heading text-neutral-900 mb-6">Our Services at a Glance</h3>
        <ul class="space-y-4 text-neutral-700">
          <li><a href="/services/tree-removal/" class="font-bold text-primary-700 hover:text-primary-800">Tree Removal</a> - Dead tree removal, hazardous tree removal, crane-assisted removal, and tree cutting &amp; felling</li>
          <li><a href="/services/emergency-tree-removal/" class="font-bold text-primary-700 hover:text-primary-800">Emergency Tree Removal</a> - 24/7 storm response, fallen tree removal, tree on house removal, and tree on car removal</li>
          <li><a href="/services/land-clearing/" class="font-bold text-primary-700 hover:text-primary-800">Land &amp; Lot Clearing</a> - Forestry mulching, brush clearing, and debris removal</li>
          <li><a href="/contact/" class="font-bold text-primary-700 hover:text-primary-800">Commercial Tree Services</a> - Large-scale tree removal and clearing for businesses, HOAs, developers, and municipalities</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-24 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <article class="bg-white rounded-2xl border border-neutral-100 p-8 shadow-sm">
          <div class="flex items-center gap-3 mb-5 text-primary-700"><Leaf size={28} /><h2 class="text-3xl font-bold font-heading text-neutral-900">Tree Removal in South Carolina</h2></div>
          <p class="text-neutral-600 mb-6">When a tree on your property becomes a safety risk, waiting is never the right option. Dead, damaged, and overgrown trees can fall without warning - putting your family, your home, and your neighbors at serious risk.</p>
          <p class="text-neutral-600 mb-8">South Carolina Tree Removal Experts has been safely removing trees of every size and species across South Carolina for over 38 years. Our crews use professional-grade equipment and proven techniques to remove any tree cleanly, safely, and without unnecessary damage to your property.</p>
          <div class="space-y-5">
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/dead-tree-removal/" class="hover:text-primary-700">Dead Tree Removal</a></h3><p class="text-neutral-600 mt-2">A dead tree might look harmless standing in your yard, but it is one of the most dangerous hazards on any property. Dead trees lose structural integrity fast and can collapse onto your home, fence, vehicle, or a family member.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/hazardous-tree-removal/" class="hover:text-primary-700">Hazardous Tree Removal</a></h3><p class="text-neutral-600 mt-2">Leaning trees, storm-split trunks, root-damaged trees, and trees growing too close to power lines or foundations all qualify as serious hazards that need immediate attention.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/crane-assisted-tree-removal/" class="hover:text-primary-700">Crane-Assisted Tree Removal</a></h3><p class="text-neutral-600 mt-2">Crane-assisted tree removal is the safest solution for large trees in tight spaces, trees overhanging rooftops, or removals near power lines and fences.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/tree-cutting-felling/" class="hover:text-primary-700">Tree Cutting &amp; Felling</a></h3><p class="text-neutral-600 mt-2">Tree cutting and felling is the controlled process of bringing a tree down safely in a planned direction after a thorough site assessment.</p></div>
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mt-8 mb-4">What to Expect When You Call Us for Tree Removal</h3>
          <p class="text-neutral-600">When you call South Carolina Tree Removal Experts, we move quickly. We schedule a free on-site assessment, give you a transparent quote with no hidden fees, and get the job scheduled at a time that works for you. From your first call to the final walkthrough, every step is handled with professionalism and care.</p>
          <div class="mt-8 rounded-xl bg-primary-50 border border-primary-100 p-5 font-bold text-primary-900">Call <a href="tel:888-643-4199" class="text-primary-700 hover:text-primary-800">(888) 643-4199</a> for a Free Tree Removal Quote - Serving All of South Carolina</div>
        </article>

        <article class="bg-white rounded-2xl border border-neutral-100 p-8 shadow-sm">
          <div class="flex items-center gap-3 mb-5 text-primary-700"><AlertTriangle size={28} /><h2 class="text-3xl font-bold font-heading text-neutral-900">Emergency Tree Removal in South Carolina - 24/7 Fast Response</h2></div>
          <p class="text-neutral-600 mb-6">When a tree falls on your home, your car, or blocks your driveway after a storm, every minute counts. South Carolina Tree Removal Experts provides 24/7 emergency tree removal services across the entire state because tree emergencies do not wait for business hours.</p>
          <p class="text-neutral-600 mb-8">Our emergency crews are fully equipped and ready to dispatch at any hour - nights, weekends, and holidays included. With 38 years of experience handling storm damage across South Carolina, we know exactly how to respond fast, work safely, and protect your property from further harm.</p>
          <div class="space-y-5">
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/emergency-storm-response/" class="hover:text-primary-700">Emergency Storm Response</a></h3><p class="text-neutral-600 mt-2">When a storm hits, our emergency storm response team mobilizes immediately to clear downed trees, remove dangerous hanging limbs, and make your property safe again.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/fallen-tree-removal/" class="hover:text-primary-700">Fallen Tree Removal</a></h3><p class="text-neutral-600 mt-2">A fallen tree blocking your driveway, crushing your fence, or lying across your yard is more than an inconvenience. We safely remove fallen trees of any size and haul away all debris.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/tree-on-house-removal/" class="hover:text-primary-700">Tree on House Removal</a></h3><p class="text-neutral-600 mt-2">A tree on your roof or against your home's structure must be handled carefully. We section and lift the tree away to prevent further damage and document the process for insurance support.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/tree-on-car-removal/" class="hover:text-primary-700">Tree on Car Removal</a></h3><p class="text-neutral-600 mt-2">A tree or large branch on your vehicle requires controlled removal to avoid additional damage. Our crew uses the right equipment and techniques to safely lift and remove the tree.</p></div>
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mt-8 mb-4">Do Not Wait - Call Us the Moment It Happens</h3>
          <p class="text-neutral-600">The longer a fallen or storm-damaged tree sits against your home, car, or property, the greater the risk of additional damage.</p>
          <div class="mt-8 rounded-xl bg-primary-50 border border-primary-100 p-5 font-bold text-primary-900">24/7 Emergency Service - Call <a href="tel:888-643-4199" class="text-primary-700 hover:text-primary-800">(888) 643-4199</a> Now</div>
        </article>

        <article class="bg-white rounded-2xl border border-neutral-100 p-8 shadow-sm">
          <div class="flex items-center gap-3 mb-5 text-primary-700"><HardHat size={28} /><h2 class="text-3xl font-bold font-heading text-neutral-900">Land &amp; Lot Clearing Services in South Carolina</h2></div>
          <p class="text-neutral-600 mb-6">Whether you are preparing a residential lot for construction, clearing overgrown acreage, or managing a large development project, South Carolina Tree Removal Experts has the equipment and experience to handle it.</p>
          <p class="text-neutral-600 mb-8">We provide professional land and lot clearing services across all of South Carolina for homeowners, developers, contractors, and large property owners. Our crews work efficiently on properties of any size - from a single residential lot in Summerville to hundreds of acres in the SC Midlands or Pee Dee region.</p>
          <div class="space-y-5">
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/forestry-mulching/" class="hover:text-primary-700">Forestry Mulching</a></h3><p class="text-neutral-600 mt-2">Forestry mulching is one of the most efficient and environmentally responsible land clearing methods available, turning cleared material into natural ground cover that protects the soil.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/brush-clearing/" class="hover:text-primary-700">Brush Clearing</a></h3><p class="text-neutral-600 mt-2">Our brush clearing service removes dense vegetation, briars, scrub trees, and overgrowth quickly and completely.</p></div>
            <div><h3 class="text-xl font-bold text-neutral-900"><a href="/services/debris-removal/" class="hover:text-primary-700">Debris Removal</a></h3><p class="text-neutral-600 mt-2">After tree removal, storm events, or land clearing projects, debris removal is the final critical step. We handle complete debris removal and haul-away.</p></div>
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mt-8 mb-4">Who Our Land Clearing Services Are For</h3>
          <p class="text-neutral-600">Homeowners clearing overgrown yards, developers preparing sites for new construction, contractors managing large projects, and agricultural landowners all rely on South Carolina Tree Removal Experts to get the job done right.</p>
          <div class="mt-8 rounded-xl bg-primary-50 border border-primary-100 p-5 font-bold text-primary-900">Get Your Free Lot Clearing Estimate - Call <a href="tel:888-643-4199" class="text-primary-700 hover:text-primary-800">(888) 643-4199</a></div>
        </article>

        <article class="bg-white rounded-2xl border border-neutral-100 p-8 shadow-sm">
          <div class="flex items-center gap-3 mb-5 text-primary-700"><Users size={28} /><h2 class="text-3xl font-bold font-heading text-neutral-900">Commercial Tree Services in South Carolina</h2></div>
          <p class="text-neutral-600 mb-6">Trees on commercial properties are not just a landscaping concern. They are a safety responsibility and a liability issue. South Carolina Tree Removal Experts provides professional commercial tree removal and clearing services for businesses, property managers, HOAs, municipalities, and developers across the entire state.</p>
          <p class="text-neutral-600 mb-8">We understand that commercial jobs require a higher level of professionalism, stricter safety standards, and the ability to work around tenants, customers, and active business operations.</p>
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">Who We Work With</h3>
          <p class="text-neutral-600 mb-6">We regularly work with property managers and landlords, homeowner associations, shopping centers and retail properties, office parks and business campuses, municipalities and government facilities, and construction developers clearing large tracts of land.</p>
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">What Our Commercial Services Include</h3>
          <p class="text-neutral-600 mb-6">Our commercial services include large-tree removal, crane-assisted removal for complex jobs, forestry mulching and lot clearing, storm-damage response for commercial properties, and ongoing tree-removal contracts for property management companies.</p>
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">Fully Licensed, Insured, and Built for Large-Scale Work</h3>
          <p class="text-neutral-600 mb-6">Commercial tree work carries significant liability, and hiring an uninsured or underqualified crew puts your business and property at serious risk. Our crew size, equipment capacity, and project management experience allow us to take on large-scale commercial projects that smaller operators cannot handle.</p>
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">Flexible Scheduling Around Your Business Operations</h3>
          <p class="text-neutral-600">Our team works around your schedule, including early morning, evening, and weekend appointments, to minimize disruption to your business, tenants, and customers.</p>
          <div class="mt-8 rounded-xl bg-primary-50 border border-primary-100 p-5 font-bold text-primary-900">Contact South Carolina Tree Removal Experts for a Commercial Consultation - Call <a href="tel:888-643-4199" class="text-primary-700 hover:text-primary-800">(888) 643-4199</a></div>
        </article>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">
      <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6 text-center">Why South Carolina Homeowners and Businesses Choose Us</h2>
      <p class="text-lg text-neutral-600 leading-relaxed text-center max-w-3xl mx-auto mb-14">Choosing the right tree removal company is not just about price. It is about trust, experience, and knowing the job will be done safely.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          ['38 Years of Experience in South Carolina', 'Experience is not something you can fake, and 38 years of hands-on tree removal work across South Carolina speaks for itself. We have handled every type of tree removal situation imaginable, from routine dead tree removals to complex crane-assisted jobs in tight commercial spaces.'],
          ['Licensed and Fully Insured in South Carolina', 'Every tree removal job carries risk. South Carolina Tree Removal Experts is fully licensed and insured, carrying comprehensive liability coverage and workers compensation on every job we take.'],
          ['Local Knowledge That Makes a Real Difference', 'We are a local South Carolina tree removal company through and through. Our crews know native tree species, seasonal storm patterns, regional soil conditions, and local regulations.'],
          ['Free Estimates With No Hidden Fees', 'We provide free, transparent estimates on every job - no hidden fees, no surprise charges, and no pressure.'],
          ['Full Cleanup Included on Every Job', 'Our job is not done when the tree comes down. Every tree removal job includes full debris cleanup and haul-away so you are never left with a pile of logs, branches, or wood chips.'],
          ['24/7 Emergency Availability', 'Tree emergencies do not follow a schedule. South Carolina Tree Removal Experts is available 24 hours a day, 7 days a week across the entire state.']
        ].map(([title, text]) => (
          <div class="rounded-2xl bg-neutral-50 border border-neutral-100 p-8">
            <div class="flex items-center gap-3 mb-4 text-primary-700"><ShieldCheck size={22} /><h3 class="text-2xl font-bold text-neutral-900">{title}</h3></div>
            <p class="text-neutral-600 leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
      <p class="text-neutral-600 leading-relaxed mt-10 max-w-4xl mx-auto">The <a href="https://www.srs.fs.usda.gov/compass/2016/09/06/a-homeowners-guide-to-dealing-with-storm-damaged-trees/" target="_blank" rel="noopener" class="text-primary-700 font-semibold hover:text-primary-800">USDA Forest Service</a> recommends that homeowners treat storm-damaged trees as urgent hazards and contact a professional tree removal service without delay.</p>
      <div class="mt-10 rounded-xl bg-primary-50 border border-primary-100 p-5 font-bold text-primary-900">Call <a href="tel:888-643-4199" class="text-primary-700 hover:text-primary-800">(888) 643-4199</a> for a Free Estimate - Licensed, Insured &amp; Ready to Help Across All of South Carolina</div>
    </div>
  </section>

  <section class="py-24 bg-neutral-900 text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-heading mb-6">How Our Tree Removal Process Works in South Carolina</h2>
        <p class="text-lg text-neutral-400">We keep our process simple, transparent, and stress-free from your very first call to the final cleanup.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          ['1', 'Call Us or Request a Free Quote', 'Tell us about your tree situation, the type of tree, its location, and any urgency involved, and we will take it from there.'],
          ['2', 'Free On-Site Assessment', 'Our experienced crew member visits your property, evaluates the tree, assesses surrounding hazards, and determines the safest removal approach.'],
          ['3', 'Transparent Quote With No Surprises', 'You will know exactly what the job involves, how long it will take, and what the total cost will be before any work begins.'],
          ['4', 'Professional Removal by an Experienced Crew', 'Our crew handles the entire removal safely and efficiently, whether it requires straightforward felling, crane-assisted lifting, or emergency extraction.'],
          ['5', 'Complete Debris Cleanup and Haul-Away', 'When the tree is down, our crew clears every branch, log, and piece of debris from your property.'],
          ['6', 'Final Walkthrough and Your Satisfaction', 'Before we close out any job, we walk the property with you to confirm everything meets your expectations.']
        ].map(([step, title, text]) => (
          <div class="bg-neutral-800 p-8 rounded-2xl border border-neutral-700">
            <div class="text-primary-500 font-bold text-5xl mb-4">{step}</div>
            <h3 class="text-xl font-bold mb-3">{title}</h3>
            <p class="text-neutral-400 leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12"><a href={`tel:${site.phone}`} class="inline-flex items-center justify-center gap-3 rounded-md bg-primary-600 px-8 py-4 font-bold text-white shadow-lg hover:bg-primary-700"><Phone size={22} /> Ready to Get Started? Call (888) 643-4199</a></div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-neutral-100">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <h2 class="text-4xl font-bold font-heading text-neutral-900 mb-16 text-center">Frequently Asked Questions About Tree Removal in South Carolina</h2>
      <div class="space-y-4">
        {[
          ['How Much Does Tree Removal Cost in South Carolina?', 'Tree removal costs in South Carolina vary depending on several factors, including the size of the tree, its location, how close it is to structures, and the method required for safe removal. We never quote a fixed price without seeing the job first, but we always provide a free, transparent estimate so you know exactly what to expect before any work begins.'],
          ['Do You Offer Free Estimates?', 'Yes. South Carolina Tree Removal Experts provides free on-site estimates on every job, with no obligation and no pressure. Simply call (888) 643-4199 and we will schedule a visit at a time that works for you.'],
