---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Calendar } from 'lucide-react';

const allBlogs = await getCollection('blogs');
// Sort by publishDate
const sortedBlogs = allBlogs
  .filter(blog => !blog.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

---

<BaseLayout 
  title="Tree Care & Removal Blog | South Carolina Tree Removal Experts"
  description="Expert advice, guides, and tips on tree removal, trimming, stump grinding, and storm damage response in South Carolina."
>
  <Header slot="header" />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-gradient-to-br from-green-950 via-green-900 to-emerald-900 text-white relative overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_1px_1px,white_1px,transparent_0)]" style="background-size: 32px 32px;"></div>
    
    <div class="container mx-auto px-4 relative z-10 max-w-5xl">
      <div class="max-w-2xl">
        <span class="text-green-400 font-semibold tracking-wider uppercase text-sm mb-4 block">Our Journal</span>
        <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
          Tree Care Tips & <br/><span class="text-green-300">Expert Advice</span>
        </h1>
        <p class="text-lg md:text-xl text-green-100 max-w-xl">
          Learn everything from identifying diseased trees to protecting your property during South Carolina storm seasons.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="py-20 bg-stone-50">
    <div class="container mx-auto px-4 max-w-7xl">
      {sortedBlogs.length === 0 ? (
        <div class="text-center py-20">
          <h2 class="text-2xl font-bold text-stone-800 mb-4">Check back soon!</h2>
          <p class="text-stone-600">We are busy preparing our first expert articles.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedBlogs.map(blog => (
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-stone-100 group flex flex-col h-full">
              {blog.data.coverImage && (
                <a href={`/blog/${blog.id}`} class="block overflow-hidden relative aspect-[16/10]">
                  <img 
                    src={blog.data.coverImage} 
                    alt={blog.data.title} 
                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                  />
                  <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors"></div>
                </a>
              )}
              
              <div class="p-8 flex flex-col flex-grow">
                <div class="flex items-center text-sm text-stone-500 mb-4">
                  <Calendar size={16} class="mr-2 text-green-600" />
                  <time datetime={blog.data.publishDate.toISOString()}>
                    {blog.data.publishDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                </div>
                
                <h2 class="text-2xl font-bold text-stone-800 mb-3 leading-tight group-hover:text-green-700 transition-colors">
                  <a href={`/blog/${blog.id}`}>
                    {blog.data.title}
                  </a>
                </h2>
                
                <p class="text-stone-600 line-clamp-3 mb-6 flex-grow">
                  {blog.data.description}
                </p>
                
                <a 
                  href={`/blog/${blog.id}`} 
                  class="inline-flex items-center text-green-700 font-semibold hover:text-green-800 transition-colors mt-auto"
                >
                  Read Article <ArrowRight size={18} class="ml-2 group-hover:translate-x-1 transition-transform" />
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
