---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import { site } from '../../data/site';
import { Calendar, User, Tag, ArrowLeft, Phone, ShieldCheck, Clock } from 'lucide-react';
import { marked } from 'marked';

const getPostSlug = (post) => post.slug || post.id.replace(/\.(md|mdoc)$/, '');

const posts = await getCollection('posts');
const authors = await getCollection('authors');
const categories = await getCollection('categories');
const tags = await getCollection('tags');
const authorNames = new Map(authors.map(author => [author.id.replace(/\.json$/, ''), author.data.name]));
const categoryNames = new Map(categories.map(category => [category.id.replace(/\.json$/, ''), category.data.name]));
const tagNames = new Map(tags.map(tag => [tag.id.replace(/\.json$/, ''), tag.data.name]));
const post = posts.find((entry) => getPostSlug(entry) === Astro.params.slug);

if (!post || post.data.draft) {
  return Astro.rewrite('/404');
}

const contentHtml = await marked.parse(post.body || '');

const pageTitle = post.data.seoTitle || `${post.data.title} | SC Tree Removal Experts Blog`;
const pageDesc = post.data.seoDescription || post.data.excerpt || `Read the latest tree care insights from South Carolina Tree Removal Experts.`;
const seoImage = post.data.ogImage || post.data.featuredImage || '/images/optimized/og-image.webp';
const authorName = authorNames.get(post.data.author) || post.data.author || 'South Carolina Tree Removal Experts';
const categoryName = categoryNames.get(post.data.category) || post.data.category;
const postTags = (post.data.tags || []).map(tag => ({ slug: tag, name: tagNames.get(tag) || tag }));

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: post.data.title, href: `/blog/${getPostSlug(post)}/` }
];

const breadcrumbSchema = { 
  "@context": "https://schema.org", 
  "@type": "BreadcrumbList", 
  "itemListElement": breadcrumbs.map((b,i)=>({
    "@type":"ListItem",
    "position":i+1,
    "name":b.name,
    "item":`${site.url}${b.href}`
  })) 
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "mainEntityOfPage": `${site.url}/blog/${getPostSlug(post)}/`,
  "headline": post.data.title,
  "description": pageDesc,
  "image": new URL(seoImage, site.url).toString(),
  "datePublished": post.data.publishDate.toISOString(),
  "dateModified": post.data.publishDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": authorName
  },
  "publisher": {
    "@type": "Organization",
    "name": site.name,
    "logo": {
      "@type": "ImageObject",
      "url": `${site.url}/images/logo-dark.png`
    }
  }
};
---

<BaseLayout title={pageTitle} description={pageDesc} canonical={post.data.canonicalUrl} image={seoImage} type="article" robots={post.data.noindex ? 'noindex,follow' : undefined}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Header slot="header" />

  <!-- ARTICLE HEADER -->
  <section class="pt-32 pb-16 bg-neutral-50 border-b border-neutral-200">
    <div class="container mx-auto px-4 max-w-4xl">
      <a href="/blog/" class="inline-flex items-center gap-2 text-primary-600 font-bold hover:text-primary-800 transition-colors mb-8"><ArrowLeft size={18} /> Back to Blog</a>
      
      <div class="flex flex-wrap items-center gap-4 text-sm font-bold text-neutral-500 mb-6 tracking-wider uppercase">
        {post.data.category && <a href={`/blog/category/${post.data.category}/`} class="text-primary-700 bg-primary-100 px-4 py-1.5 rounded-full hover:bg-primary-200 transition-colors">{categoryName}</a>}
        <span class="flex items-center gap-2"><Calendar size={16} /> {post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
        <span class="flex items-center gap-2"><User size={16} /> {authorName}</span>
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading text-neutral-900 leading-tight mb-8">{post.data.title}</h1>
      
      {post.data.excerpt && <p class="text-xl text-neutral-600 leading-relaxed mb-8 border-l-4 border-primary-500 pl-6 italic">{post.data.excerpt}</p>}
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 xl:gap-16 items-start">
        <div class="lg:col-span-8">
          {post.data.featuredImage && (
            <div class="mb-14 rounded-3xl overflow-hidden shadow-xl border border-neutral-100">
              <img src={post.data.featuredImage} alt={post.data.title} class="w-full h-auto object-cover max-h-[600px]" />
            </div>
          )}

          <article class="prose prose-lg md:prose-xl prose-primary max-w-none prose-img:rounded-2xl prose-img:shadow-md prose-headings:font-heading prose-a:text-primary-600 hover:prose-a:text-primary-800">
            <Fragment set:html={contentHtml} />
          </article>

          {postTags.length > 0 && (
            <div class="mt-16 pt-8 border-t border-neutral-200 flex flex-wrap items-center gap-3">
              <Tag size={20} class="text-neutral-400 mr-2" />
              {postTags.map(tag => (
                <a href={`/blog/tag/${tag.slug}/`} class="bg-neutral-100 text-neutral-600 px-4 py-2 rounded-full text-sm font-bold hover:bg-neutral-200 transition-colors">{tag.name}</a>
              ))}
            </div>
          )}
        </div>

        <aside class="lg:col-span-4 space-y-6 lg:sticky lg:top-28">
          <div class="rounded-3xl bg-neutral-900 p-7 text-white shadow-2xl">
            <p class="text-sm font-bold uppercase tracking-wider text-primary-300 mb-3">Need Tree Service?</p>
            <h2 class="text-2xl font-bold font-heading leading-tight mb-4">Get a Free Arborist Estimate</h2>
            <p class="text-neutral-300 text-sm leading-relaxed mb-6">Licensed, insured crews serving South Carolina with emergency response and no-obligation quotes.</p>
            <a href={`tel:${site.phone}`} class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-primary-600 px-5 py-3 font-bold text-white transition-all hover:bg-primary-700">
              <Phone size={18} /> {site.phone}
            </a>
          </div>

          <ContactForm title="Request Service" subtitle="We typically respond within 1 hour." iframeHeight={680} />

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-4">
            <div class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm flex items-center gap-4">
              <ShieldCheck size={30} class="text-primary-600 shrink-0" />
              <div>
                <p class="font-bold text-neutral-900">Licensed & Insured</p>
                <p class="text-xs text-neutral-500">Protected tree work statewide</p>
              </div>
            </div>
            <div class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm flex items-center gap-4">
              <Clock size={30} class="text-primary-600 shrink-0" />
              <div>
                <p class="font-bold text-neutral-900">24/7 Response</p>
                <p class="text-xs text-neutral-500">Emergency storm service</p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="py-16 bg-neutral-900 text-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-5">Need Professional Tree Service?</h2>
      <p class="text-neutral-300 text-lg mb-8 leading-relaxed">Our ISA-Certified Arborists provide safe, reliable, and insured tree removal, pruning, and land clearing across South Carolina.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="inline-flex justify-center rounded-md bg-primary-600 px-8 py-4 text-lg font-bold text-white shadow-xl transition-all hover:bg-primary-700">Get a Free Estimate</a>
        <a href={`tel:${site.phone}`} class="inline-flex justify-center rounded-md border border-white/20 bg-white/10 px-8 py-4 text-lg font-bold text-white transition-all hover:bg-white/20">{site.phone}</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
