---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { Calendar, ChevronLeft, ShieldCheck, Award } from 'lucide-react';
import { site } from '../../data/site';
import { services } from '../../data/services';

export async function getStaticPaths() {
  const blogs = await getCollection('blogs');
  return blogs.map(blog => ({
    params: { slug: blog.id },
    props: { blog },
  }));
}

const { blog } = Astro.props;
const { Content } = await render(blog);

// Fetch Author Data
const author = await getEntry(blog.data.author);

// Schema.org E-E-A-T Data
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": blog.data.title,
  "description": blog.data.description,
  "image": blog.data.coverImage ? new URL(blog.data.coverImage, Astro.site).toString() : undefined,
  "datePublished": blog.data.publishDate.toISOString(),
  "dateModified": blog.data.updatedDate ? blog.data.updatedDate.toISOString() : blog.data.publishDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": author?.data.name,
    "jobTitle": author?.data.role,
  }
};
---

<BaseLayout 
  title={blog.data.title}
  description={blog.data.description}
  image={blog.data.coverImage}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Header slot="header" transparent={false} />
  
  <article class="pt-32 pb-20 bg-neutral-50 min-h-screen">
    <div class="container mx-auto px-4 max-w-7xl">
      <!-- Back Link -->
      <a href="/blog" class="inline-flex items-center text-neutral-500 hover:text-primary-600 transition-colors mb-8 font-medium">
        <ChevronLeft size={20} class="mr-1" /> Back to all articles
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content Column -->
        <div class="lg:col-span-2">
          <!-- Header -->
          <header class="mb-12">
            <div class="flex flex-wrap items-center gap-4 text-sm font-bold tracking-wide text-primary-600 uppercase mb-4">
              <span class="bg-primary-50 px-3 py-1 rounded-full border border-primary-100">Tree Care Guide</span>
              <div class="flex items-center text-neutral-500">
                <Calendar size={16} class="mr-1.5" />
                <time datetime={blog.data.publishDate.toISOString()}>
                  {blog.data.publishDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </div>
            </div>
            
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 leading-tight mb-8 font-heading">
              {blog.data.title}
            </h1>

            {blog.data.coverImage && (
              <div class="rounded-2xl overflow-hidden shadow-lg border border-neutral-200">
                <img 
                  src={blog.data.coverImage} 
                  alt={blog.data.title} 
                  class="w-full aspect-video object-cover"
                />
              </div>
            )}
          </header>

          <!-- Prose Content -->
          <div class="prose prose-lg md:prose-xl prose-neutral max-w-none font-body prose-headings:font-heading prose-headings:font-bold prose-headings:text-neutral-900 prose-a:text-primary-600 hover:prose-a:text-primary-700 prose-img:rounded-2xl prose-img:shadow-md mb-16">
            <Content />
          </div>

          <!-- Author Bio Box (E-E-A-T Signal) -->
          {author && (
            <div class="bg-neutral-100 rounded-2xl p-8 flex flex-col sm:flex-row gap-6 items-start border border-neutral-200 mb-16">
              {author.data.avatar ? (
                <img src={author.data.avatar} alt={author.data.name} class="w-24 h-24 rounded-full object-cover shadow-md shrink-0" />
              ) : (
                <div class="w-24 h-24 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-3xl font-bold shrink-0">
                  {author.data.name.charAt(0)}
                </div>
              )}
              <div>
                <h3 class="text-xl font-bold font-heading text-neutral-900 mb-1">{author.data.name}</h3>
                <div class="flex items-center text-primary-700 font-medium text-sm mb-3">
                  <ShieldCheck size={16} class="mr-1" /> {author.data.role}
                </div>
                {author.data.bio && <p class="text-neutral-600 leading-relaxed mb-4">{author.data.bio}</p>}
                
                <div class="flex flex-wrap gap-2">
                  <span class="inline-flex items-center text-xs font-semibold bg-white border border-neutral-200 text-neutral-600 px-2.5 py-1 rounded-md">
                    <Award size={14} class="mr-1 text-yellow-500" /> Locally Owned
                  </span>
                  <span class="inline-flex items-center text-xs font-semibold bg-white border border-neutral-200 text-neutral-600 px-2.5 py-1 rounded-md">
                    <ShieldCheck size={14} class="mr-1 text-green-600" /> Licensed & Insured
                  </span>
                </div>
              </div>
            </div>
          )}

          <!-- Bottom CTA -->
          <div class="mt-16 p-8 bg-gradient-to-br from-primary-900 to-primary-800 rounded-2xl text-white shadow-xl relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_1px_1px,white_1px,transparent_0)]" style="background-size: 24px 24px;"></div>
            <div class="relative z-10 text-center">
              <h3 class="text-2xl font-bold font-heading mb-4">Need Professional Tree Assistance?</h3>
              <p class="text-primary-100 mb-8 max-w-lg mx-auto">Don't wait for a storm to expose a hazard. Get a free, no-obligation estimate from South Carolina's trusted arborists.</p>
              <a href="/contact" class="inline-block bg-white text-primary-800 font-bold py-3 px-8 rounded-lg shadow hover:bg-neutral-50 hover:shadow-lg transition-all transform hover:-translate-y-1">
                Request Your Free Estimate
              </a>
            </div>
          </div>
        </div>

        <!-- Sticky Sidebar Column -->
        <aside class="lg:col-span-1 relative">
          <div class="sticky top-32 space-y-8">
            <!-- Lead Gen CTA Widget -->
            <div class="bg-white rounded-2xl shadow-lg border border-neutral-100 overflow-hidden">
              <div class="bg-primary-600 p-6 text-white text-center">
                <h3 class="font-bold font-heading text-xl mb-2">Emergency Service Available</h3>
                <p class="text-primary-100 text-sm">We respond 24/7 across South Carolina.</p>
              </div>
              <div class="p-6 text-center">
                <p class="text-neutral-600 mb-6 text-sm">Call us directly for immediate assistance or to schedule a free property assessment.</p>
                <a href={`tel:${site.phone}`} class="flex items-center justify-center gap-2 bg-primary-50 text-primary-700 border border-primary-200 font-bold py-3 px-4 rounded-lg hover:bg-primary-600 hover:text-white transition-colors group mb-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:animate-bounce"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {site.phone}
                </a>
                <a href="/contact" class="block text-sm text-primary-600 font-semibold hover:underline">Or send us a message</a>
              </div>
            </div>

            <!-- Core Services Widget -->
            <div class="bg-white rounded-2xl shadow-lg border border-neutral-100 p-6">
              <h3 class="font-bold font-heading text-lg text-neutral-900 mb-4 border-b border-neutral-100 pb-3">Our Core Services</h3>
              <ul class="space-y-3">
                {services.map(service => (
                  <li>
                    <a href={`/services/${service.slug}`} class="flex items-center justify-between text-neutral-600 hover:text-primary-600 font-medium transition-colors group">
                      <span>{service.name}</span>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
