---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { site } from '../../../data/site';
import { Calendar, ArrowRight } from 'lucide-react';

const getPostSlug = (post) => post.slug || post.id.replace(/\.(md|mdoc)$/, '');

const categories = await getCollection('categories');
const posts = await getCollection('posts');
const category = categories.find(item => item.id.replace(/\.json$/, '') === Astro.params.slug);

if (!category) {
  return Astro.rewrite('/404');
}

const categorySlug = category.id.replace(/\.json$/, '');
const visiblePosts = posts
  .filter(post => !post.data.draft && post.data.category === categorySlug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

if (visiblePosts.length === 0) {
  return Astro.rewrite('/404');
}

const pageTitle = `${category.data.name} Blog Posts | South Carolina Tree Removal Experts`;
const pageDesc = `Read ${category.data.name.toLowerCase()} articles from South Carolina Tree Removal Experts.`;
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: category.data.name, href: `/blog/category/${categorySlug}/` },
];
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: `${site.url}${item.href}`,
  })),
};
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Header slot="header" />

  <section class="relative pt-32 pb-20 bg-neutral-900 text-white">
    <div class="container mx-auto px-4 max-w-5xl text-center">
      <p class="text-primary-300 font-bold uppercase tracking-wider mb-4">Blog Category</p>
      <h1 class="text-4xl md:text-6xl font-bold font-heading">{category.data.name}</h1>
    </div>
  </section>

  <section class="py-20 bg-neutral-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {visiblePosts.map(post => (
          <a href={`/blog/${getPostSlug(post)}/`} class="group bg-white rounded-2xl border border-neutral-200 overflow-hidden shadow-sm hover:shadow-xl transition-all">
            {post.data.featuredImage && <img src={post.data.featuredImage} alt={post.data.title} class="w-full h-52 object-cover" />}
            <div class="p-7">
              <p class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-neutral-500 mb-4"><Calendar size={14} /> {post.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
              <h2 class="text-2xl font-bold font-heading text-neutral-900 mb-4 group-hover:text-primary-600 transition-colors">{post.data.title}</h2>
              <p class="text-neutral-600 line-clamp-3 mb-6">{post.data.excerpt || post.data.seoDescription || 'Read the latest tree care insight.'}</p>
              <span class="inline-flex items-center gap-2 text-primary-600 font-bold">Read More <ArrowRight size={16} /></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
