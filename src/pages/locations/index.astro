---
import { locations } from '../../data/locations';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site';
import { AnimatedIcon } from '../../components/AnimatedIcon';
import { Phone, MapPin, Map, CheckCircle, Clock, ShieldCheck, Star } from 'lucide-react';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Service Areas', href: '/locations' }
];
---

<BaseLayout 
  title="Our Service Areas Across South Carolina | Lowcountry to Upstate"
  description="South Carolina Tree Removal serves the entire Palmetto State. From Charleston and Myrtle Beach to Columbia and Greenville, we provide 24/7 coverage."
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-24 md:pt-48 md:pb-36 bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-primary-900/85 backdrop-blur-sm z-10"></div>
      <img src="https://picture-search.skywork.ai/skills/upload/2026-04-16/438fa771a73e413c815faef379945eaa_03ffd.png" alt="South Carolina Service Area Coverage" class="w-full h-full object-cover" />
    </div>

    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-20 text-center text-white">
      <nav class="flex justify-center mb-8">
        <ol class="flex items-center gap-2 text-sm font-medium text-primary-200">
          {breadcrumbs.map((bc, idx) => (
            <li class="flex items-center gap-2">
              <a href={bc.href} class="hover:text-white transition-colors">{bc.name}</a>
              {idx < breadcrumbs.length - 1 && <span class="text-primary-500">/</span>}
            </li>
          ))}
        </ol>
      </nav>
      <h1 class="text-4xl md:text-6xl font-bold font-heading mb-8 leading-tight max-w-4xl mx-auto">
        Serving the Entire <span class="text-primary-400">Palmetto State</span>
      </h1>
      <p class="text-xl text-primary-50 max-w-2xl mx-auto leading-relaxed mb-12">
        We provide professional arborist services from 4 regional hubs, ensuring rapid 24/7 response to any SC property.
      </p>
    </div>
  </section>

  <!-- Regional Grid Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {locations.map(loc => (
          <a href={`/locations/${loc.slug}/`} class="group bg-neutral-50 rounded-2xl overflow-hidden border border-neutral-200 hover:border-primary-500 hover:bg-white hover:shadow-2xl transition-all duration-300 flex flex-col h-full">
            <div class="h-48 overflow-hidden relative">
              <img src={loc.image} alt={loc.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute top-4 right-4">
                <span class="bg-white/90 backdrop-blur-sm text-primary-700 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest shadow-sm">
                  {loc.county}
                </span>
              </div>
            </div>
            <div class="p-8 flex flex-col flex-grow">
              <div class="flex items-center gap-3 mb-4">
                <AnimatedIcon client:load icon={MapPin} className="text-primary-600 group-hover:text-primary-700" animation="bounce" />
                <h3 class="text-2xl font-bold font-heading text-neutral-900 group-hover:text-primary-700 transition-colors">{loc.name}, SC</h3>
              </div>
              <p class="text-neutral-600 mb-8 leading-relaxed line-clamp-2">
                Expert arborist-led services throughout {loc.name} and surrounding communities including {loc.neighborhoods.slice(0, 3).join(', ')}.
              </p>
              <div class="mt-auto flex items-center justify-between">
                <span class="text-primary-600 font-bold flex items-center gap-2">
                  View Local Details <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Statewide Map Feature -->
  <section class="py-24 bg-neutral-900 text-white relative overflow-hidden">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold font-heading mb-8 leading-tight">True Statewide <span class="text-primary-400">24/7</span> Emergency Coverage</h2>
          <p class="text-xl text-neutral-400 mb-10 leading-relaxed">
            Unlike many tree companies that stay in one metro area, South Carolina Tree Removal is built for scale. With mobile equipment and regional hubs, we can be anywhere in SC within hours of a storm.
          </p>
          <ul class="space-y-6">
            <li class="flex items-center gap-4">
              <div class="bg-primary-600 p-2 rounded-full text-white">
                <CheckCircle size={20} />
              </div>
              <p class="text-lg font-medium">The Lowcountry Hub: Charleston & Hilton Head</p>
            </li>
            <li class="flex items-center gap-4">
              <div class="bg-primary-600 p-2 rounded-full text-white">
                <CheckCircle size={20} />
              </div>
              <p class="text-lg font-medium">The Midlands Hub: Columbia & Lexington</p>
            </li>
            <li class="flex items-center gap-4">
              <div class="bg-primary-600 p-2 rounded-full text-white">
                <CheckCircle size={20} />
              </div>
              <p class="text-lg font-medium">The Upstate Hub: Greenville & Spartanburg</p>
            </li>
            <li class="flex items-center gap-4">
              <div class="bg-primary-600 p-2 rounded-full text-white">
                <CheckCircle size={20} />
              </div>
              <p class="text-lg font-medium">Grand Strand Hub: Myrtle Beach & Pee Dee</p>
            </li>
          </ul>
        </div>
        <div class="relative">
           <div class="bg-neutral-800 p-8 rounded-3xl border border-neutral-700 shadow-2xl overflow-hidden h-[500px]">
              <!-- Mock Map Placeholder or Static Image would go here -->
              <div class="w-full h-full bg-neutral-700 flex items-center justify-center rounded-2xl relative overflow-hidden group">
                 <img src="https://picture-search.skywork.ai/skills/upload/2026-04-16/a365f5a750944a83a81e269d16a46d1d_b0bfe.png" alt="South Carolina Coverage Map" class="w-full h-full object-cover opacity-50 grayscale group-hover:grayscale-0 transition-all duration-700" />
                 <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-10 pointer-events-none">
                    <Map size={64} className="text-primary-500 mb-6 group-hover:scale-125 transition-transform" />
                    <p class="text-2xl font-bold font-heading text-white">450+ Municipalities Served</p>
                    <p class="text-neutral-400 mt-2">Professional Care in Every Corner of SC</p>
                 </div>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-white text-center">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <h2 class="text-3xl md:text-5xl font-bold font-heading text-neutral-900 mb-8 leading-tight">Don't See Your Location Listed?</h2>
      <p class="text-xl text-neutral-600 mb-12 leading-relaxed">
        We serve rural areas and all smaller municipalities across the state. If you have a South Carolina zip code, we have a crew that can help.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="bg-primary-600 hover:bg-primary-700 text-white px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-800 transition-all shadow-xl">
          Request a Free Estimate
        </a>
        <a href={`tel:${site.phone}`} class="bg-neutral-100 text-neutral-900 border border-neutral-200 px-10 py-5 rounded-md font-bold text-xl hover:bg-neutral-200 transition-all flex items-center justify-center gap-3">
          <Phone size={24} />
          {site.phone}
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
