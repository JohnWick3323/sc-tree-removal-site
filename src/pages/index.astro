---
import { site } from '../data/site';
import { Phone, CheckCircle, ShieldCheck, Zap, HardHat, MapPin, ClipboardCheck, Leaf, ChevronDown, Award, Users, AlertTriangle } from 'lucide-react';
import { AnimatedIcon } from '../components/AnimatedIcon';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { services } from '../data/services';
import { locations } from '../data/locations';

import ContactForm from '../components/ContactForm.astro';

const featuredServices = services.slice(0, 4);
const topLocations = locations.slice(0, 6);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${site.url}/#organization`,
  "name": site.name,
  "legalName": site.legalName,
  "url": site.url,
  "telephone": site.phone,
  "email": site.email,
  "logo": `${site.url}/images/logo.png`,
  "image": `${site.url}/images/optimized/og-image.webp`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": site.address.street,
    "addressLocality": site.address.city,
    "addressRegion": site.address.state,
    "postalCode": site.address.zip,
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "State",
    "name": "South Carolina"
  },
  "serviceType": [
    "Tree Removal",
    "Stump Grinding",
    "Emergency Storm Response",
    "Land Clearing",
    "Commercial Forestry"
  ],
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "500",
    "bestRating": "5",
    "worstRating": "1"
  }
};

const homeBreadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": site.url
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need a permit to remove a tree in South Carolina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Permit requirements vary by municipality. For example, Charleston strictly protects 'Grand Trees' (24+ inches DBH), while Greenville and Columbia have their own landscape ordinances. We handle all local permit applications to ensure your tree removal is 100% legal and compliant."
      }
    },
    {
      "@type": "Question",
      "name": "How can I tell if my oak or pine tree is diseased?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common SC tree issues like Oak Wilt, Oak Leaf Blister, or Southern Pine Beetle infestations often present as thinning canopies, early leaf drop, or sawdust at the trunk base. If you notice these signs, contact us for a professional health assessment."
      }
    },
    {
      "@type": "Question",
      "name": "Does homeowners insurance cover tree removal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If a tree falls on a covered structure (like your house or fence) due to a storm, your insurance typically covers the removal cost. We work directly with local SC insurance adjusters to streamline your claim process."
      }
    },
    {
      "@type": "Question",
      "name": "What do you do with the wood and stump?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We offer comprehensive cleanup. We can haul all debris away, chip the branches into landscape mulch, or leave the wood cut to firewood length. We also provide professional stump grinding."
      }
    }
  ]
};
---

<BaseLayout 
  title="Expert Tree Removal in South Carolina | South Carolina Tree Removal Experts"
  description="ISA-certified Arborists serving all of South Carolina. Tree removal, stump grinding & 24/7 storm response. Serving Charleston, Greenville & Columbia. Free estimates — call today."
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(homeBreadcrumbs)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header slot="header" />
  
  <!-- Hero Section -->
  <section class="relative min-h-[95vh] flex items-center pt-24 pb-20 overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/40 z-10"></div>
      <img src="/images/optimized/hero-home.webp" alt="South Carolina Tree Removal Experts Crew at Work" class="w-full h-full object-cover" />
    </div>

    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-20">
      <div class="max-w-2xl text-white">
        <div class="inline-flex items-center gap-2 bg-primary-600/30 backdrop-blur-md border border-primary-500/40 px-4 py-2 rounded-full mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="text-sm font-semibold tracking-wide uppercase">Fully Licensed & Insured SC Experts</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-bold font-heading mb-8 leading-[1.1]">
          Professional Tree Removal <span class="text-primary-400">Across All of South Carolina</span>
        </h1>
        <p class="text-lg md:text-xl text-neutral-200 mb-12 leading-relaxed max-w-xl">
          From 24/7 emergency storm response to Arborist-led residential removal, we provide safe, professional tree services across all of South Carolina.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/contact/" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1 text-center">
            Get a Free Estimate
          </a>
          <a href="tel:(888) 643-4199" class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-md font-bold text-lg transition-all text-center flex items-center justify-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (888) 643-4199
          </a>
        </div>

        <!-- Trust Stats -->
        <div class="relative bg-black/40 backdrop-blur-md p-6 md:p-8 rounded-3xl border border-white/10 mt-12 w-full lg:w-fit">
          <div class="flex flex-col sm:flex-row items-center gap-y-6 gap-x-10 md:gap-x-12 sm:divide-x divide-white/10">
            <div class="flex items-baseline gap-2 w-full sm:w-auto justify-center sm:justify-start">
              <span class="text-4xl font-black text-primary-400">24/7</span>
              <span class="text-xs font-bold uppercase tracking-widest text-white">Response</span>
            </div>
            <div class="flex items-baseline gap-2 w-full sm:w-auto justify-center sm:justify-start sm:pl-10 md:pl-12">
              <span class="text-4xl font-black text-primary-400">500+</span>
              <span class="text-xs font-bold uppercase tracking-widest text-white">Served</span>
            </div>
            <div class="flex items-baseline gap-2 w-full sm:w-auto justify-center sm:justify-start sm:pl-10 md:pl-12">
              <span class="text-4xl font-black text-primary-400">100%</span>
              <span class="text-xs font-bold uppercase tracking-widest text-white">Safe</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Strip -->
  <section class="relative z-30 mb-12">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="bg-white rounded-3xl shadow-2xl border border-neutral-100 p-10 md:p-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
          <div class="flex items-start gap-5 group">
            <div class="bg-primary-50 p-5 rounded-2xl text-primary-600 group-hover:bg-primary-600 group-hover:text-white transition-all duration-300 shadow-sm shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14.5L12 3l8 11.5L12 21l-8-6.5z"/></svg>
            </div>
            <div>
              <h3 class="font-black text-neutral-900 text-lg leading-tight mb-2 uppercase tracking-tighter italic">Rapid Response</h3>
              <p class="text-sm text-neutral-500 font-medium leading-relaxed">On-site within hours for SC emergencies</p>
            </div>
          </div>
          <div class="flex items-start gap-5 group">
            <div class="bg-primary-50 p-5 rounded-2xl text-primary-600 group-hover:bg-primary-600 group-hover:text-white transition-all duration-300 shadow-sm shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h3 class="font-black text-neutral-900 text-lg leading-tight mb-2 uppercase tracking-tighter italic">Fully Insured</h3>
              <p class="text-sm text-neutral-500 font-medium leading-relaxed">Comprehensive South Carolina coverage</p>
            </div>
          </div>
          <div class="flex items-start gap-5 group">
            <div class="bg-primary-50 p-5 rounded-2xl text-primary-600 group-hover:bg-primary-600 group-hover:text-white transition-all duration-300 shadow-sm shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18a5 5 0 0 0 5 5h10a5 5 0 0 0 5-5v-2H2v2Z"/><path d="M9 10a3 3 0 0 1 6 0v4H9v-4Z"/><path d="M22 13a2 2 0 1 1-4 0 2 2 0 0 1 4 0Z"/><path d="M6 13a2 2 0 1 1-4 0 2 2 0 0 1 4 0Z"/></svg>
            </div>
            <div>
              <h3 class="font-black text-neutral-900 text-lg leading-tight mb-2 uppercase tracking-tighter italic">Expert Arborists</h3>
              <p class="text-sm text-neutral-500 font-medium leading-relaxed">Certified local SC professionals</p>
            </div>
          </div>
          <div class="flex items-start gap-5 group">
            <div class="bg-primary-50 p-5 rounded-2xl text-primary-600 group-hover:bg-primary-600 group-hover:text-white transition-all duration-300 shadow-sm shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>
              <h3 class="font-black text-neutral-900 text-lg leading-tight mb-2 uppercase tracking-tighter italic">Zero-Impact</h3>
              <p class="text-sm text-neutral-500 font-medium leading-relaxed">Guaranteed property protection</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Global Contact Form (Homepage Special) -->
  <section class="py-24 bg-white border-b border-neutral-100">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div>
          <h2 class="text-base font-bold text-primary-600 uppercase tracking-widest mb-4 text-center lg:text-left">Immediate Assistance</h2>
          <p class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-8 leading-tight text-center lg:text-left">
            Ready to Clear Your Property <span class="text-primary-600">Safely?</span>
          </p>
          <p class="text-lg text-neutral-600 mb-10 leading-relaxed text-center lg:text-left">
            Don't leave your property's safety to chance. Our certified Arborist team provides detailed assessments and safe removal services across South Carolina.
          </p>
          <div class="flex flex-col sm:flex-row items-center gap-10 justify-center lg:justify-start">
             <div class="text-center">
                <p class="text-3xl font-black text-neutral-900">24/7</p>
                <p class="text-xs font-bold text-neutral-400 uppercase tracking-widest">Emergency Dispatch</p>
             </div>
             <div class="w-px h-12 bg-neutral-200 hidden sm:block"></div>
             <div class="text-center">
                <p class="text-3xl font-black text-neutral-900">Zero</p>
                <p class="text-xs font-bold text-neutral-400 uppercase tracking-widest">Property Damage</p>
             </div>
             <div class="w-px h-12 bg-neutral-200 hidden sm:block"></div>
             <div class="text-center">
                <p class="text-3xl font-black text-neutral-900">ISA</p>
                <p class="text-xs font-bold text-neutral-400 uppercase tracking-widest">Certified Crews</p>
             </div>
          </div>
        </div>
        <div>
          <ContactForm title="Get Your Free Estimate" />
        </div>
      </div>
    </div>
  </section>

  <!-- How Our Process Works -->
  <section class="py-24 bg-neutral-50 border-b border-neutral-100">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-base font-bold text-primary-600 uppercase tracking-widest mb-4">Our Proven Process</h2>
        <p class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Safe, Compliant & Zero-Impact</p>
        <p class="text-lg text-neutral-600">From handling local SC permits to final cleanup, we manage every step so you don't have to.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="bg-white p-10 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 border border-neutral-100 relative group">
          <div class="absolute top-0 right-0 p-8 text-neutral-100 font-black text-8xl leading-none z-0 group-hover:text-primary-50 transition-colors">1</div>
          <div class="relative z-10">
            <div class="bg-primary-50 w-16 h-16 rounded-2xl flex items-center justify-center text-primary-600 mb-8 group-hover:bg-primary-600 group-hover:text-white transition-all shadow-sm">
              <ClipboardCheck size={32} />
            </div>
            <h3 class="text-2xl font-bold font-heading text-neutral-900 mb-4">Free Assessment & Permits</h3>
            <p class="text-neutral-600 leading-relaxed">
              Our ISA Certified arborists evaluate your tree's health and identify any local SC permit requirements (such as Charleston's Grand Tree ordinance or Columbia's rules). We provide a transparent, no-obligation quote.
            </p>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="bg-white p-10 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 border border-neutral-100 relative group">
          <div class="absolute top-0 right-0 p-8 text-neutral-100 font-black text-8xl leading-none z-0 group-hover:text-primary-50 transition-colors">2</div>
          <div class="relative z-10">
            <div class="bg-primary-50 w-16 h-16 rounded-2xl flex items-center justify-center text-primary-600 mb-8 group-hover:bg-primary-600 group-hover:text-white transition-all shadow-sm">
              <HardHat size={32} />
            </div>
            <h3 class="text-2xl font-bold font-heading text-neutral-900 mb-4">Safe Execution</h3>
            <p class="text-neutral-600 leading-relaxed">
              Using advanced rigging and state-of-the-art equipment, we safely dismantle hazardous or storm-damaged trees—even in tight spaces—protecting your home and property during hurricane season.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="bg-white p-10 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 border border-neutral-100 relative group">
          <div class="absolute top-0 right-0 p-8 text-neutral-100 font-black text-8xl leading-none z-0 group-hover:text-primary-50 transition-colors">3</div>
          <div class="relative z-10">
            <div class="bg-primary-50 w-16 h-16 rounded-2xl flex items-center justify-center text-primary-600 mb-8 group-hover:bg-primary-600 group-hover:text-white transition-all shadow-sm">
              <Leaf size={32} />
            </div>
            <h3 class="text-2xl font-bold font-heading text-neutral-900 mb-4">Zero-Impact Cleanup</h3>
            <p class="text-neutral-600 leading-relaxed">
              We treat your property like our own. From complete debris removal to professional stump grinding, we leave your South Carolina yard immaculate and ready for landscaping.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-base font-bold text-primary-600 uppercase tracking-widest mb-4">Our Professional Services</h2>
        <p class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Expert Tree Care Solutions for Every Property</p>
        <p class="text-lg text-neutral-600">Whether you need a hazardous tree removed from a tight residential spot or large-scale land clearing for development, our SC-based team has the equipment and expertise to get it done safely.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {featuredServices.map(service => (
          <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-neutral-100 flex flex-col sm:flex-row">
            <div class="sm:w-2/5 relative h-64 sm:h-auto overflow-hidden">
              <img src={service.image || `/images/services/${service.slug}.webp`} alt={service.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-8 sm:w-3/5 flex flex-col">
              <h3 class="text-2xl font-bold font-heading mb-4 group-hover:text-primary-600 transition-colors">{service.name}</h3>
              <p class="text-neutral-600 mb-6 line-clamp-3 leading-relaxed">
                {service.description}
              </p>
              <div class="mt-auto">
                <a href={`/services/${service.slug}/`} class="text-primary-600 font-bold flex items-center gap-2 group/link">
                  Learn More <span class="group-hover/link:translate-x-1 transition-transform">&rarr;</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/services/" class="inline-flex items-center gap-2 bg-neutral-900 text-white px-8 py-4 rounded-md font-bold hover:bg-neutral-800 transition-colors">
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-primary-600 relative overflow-hidden">
    <div class="absolute inset-0 bg-neutral-900/10 z-0"></div>
    <div class="container mx-auto px-4 md:px-8 max-w-4xl relative z-10 text-center">
      <h2 class="text-3xl md:text-5xl font-bold font-heading text-white mb-8 leading-tight">
        Need Immediate Assistance After a Storm?
      </h2>
      <p class="text-xl text-primary-50 mb-12 max-w-2xl mx-auto leading-relaxed">
        Our emergency crews are on standby 24/7 across South Carolina to handle hazardous fallen trees and protect your property.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:(888) 643-4199" class="bg-white text-primary-700 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-50 transition-all shadow-xl flex items-center justify-center gap-3">
          <Phone size={24} />
          (888) 643-4199
        </a>
        <a href="/contact/" class="bg-primary-800 text-white border border-primary-500 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-900 transition-all text-center">
          Schedule Free Quote
        </a>
      </div>
    </div>
  </section>

  <!-- Locations Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-8">
        <div class="max-w-2xl">
          <h2 class="text-base font-bold text-primary-600 uppercase tracking-widest mb-4">Statewide Coverage</h2>
          <p class="text-4xl md:text-5xl font-bold font-heading text-neutral-900">Serving all of South Carolina from 4 Regional Hubs</p>
        </div>
        <a href="/locations/" class="text-primary-600 font-bold flex items-center gap-2 hover:translate-x-1 transition-transform pb-2">
          View All Service Areas &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {topLocations.map(loc => (
          <a href={`/locations/${loc.slug}/`} class="group p-8 bg-neutral-50 rounded-xl border border-neutral-200 hover:border-primary-500 hover:bg-primary-50 transition-all duration-300">
            <div class="flex justify-between items-start mb-6">
              <div class="bg-white p-3 rounded-lg shadow-sm group-hover:bg-primary-600 group-hover:text-white transition-colors">
                <MapPin size={24} />
              </div>
              <span class="text-xs font-bold text-neutral-400 uppercase tracking-widest">{loc.county}</span>
            </div>
            <h3 class="text-2xl font-bold font-heading text-neutral-900 group-hover:text-primary-700 transition-colors mb-2">{loc.name}</h3>
            <p class="text-neutral-500 text-sm mb-6">Professional Arborist services in {loc.name} and surrounding neighborhoods.</p>
            <div class="flex items-center text-primary-600 font-bold text-sm">
              View Services <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Local Experts (E-E-A-T) -->
  <section class="py-24 bg-neutral-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/optimized/hero-home.webp')] opacity-10 bg-cover bg-center mix-blend-overlay"></div>
    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-base font-bold text-primary-400 uppercase tracking-widest mb-4">South Carolina's Trusted Tree Care</h2>
          <p class="text-4xl md:text-5xl font-bold font-heading mb-8 leading-tight">
            Local Experts Who Understand <span class="text-primary-400">SC Environments</span>
          </p>
          <p class="text-lg text-neutral-300 mb-10 leading-relaxed">
            When dealing with dead, diseased, or storm-damaged trees, you need a local team. From handling Southern Pine Beetle infestations to hurricane preparation, our fully licensed arborists deliver safe, efficient, and code-compliant tree care across the state.
          </p>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="bg-primary-600/20 p-3 rounded-xl text-primary-400 mt-1">
                <Award size={24} />
              </div>
              <div>
                <h4 class="text-xl font-bold mb-1">ISA Certified Arborists</h4>
                <p class="text-neutral-400">Our staff includes certified experts trained in tree health and risk assessment.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-primary-600/20 p-3 rounded-xl text-primary-400 mt-1">
