---
import { site } from '../data/site';
import { getCollection } from 'astro:content';
import { Phone, ShieldCheck, HardHat, MapPin, ClipboardCheck, ChevronDown, Award, Calendar, ArrowRight } from 'lucide-react';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
const getPostSlug = (post) => post.slug || post.id.replace(/\.(md|mdoc)$/, '');
const getPostExcerpt = (post) => post.data.excerpt || post.data.seoDescription || 'Read the latest tree care insight from South Carolina Tree Removal Experts.';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${site.url}/#organization`,
  "name": site.name,
  "legalName": site.legalName,
  "url": site.url,
  "telephone": site.phone,
  "email": site.email,
  "logo": `${site.url}/images/logo.png`,
  "image": `${site.url}/images/optimized/og-image.webp`,
  "hasMap": `${site.url}/contact/`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": site.address.street,
    "addressLocality": site.address.city,
    "addressRegion": site.address.state,
    "postalCode": site.address.zip,
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "State",
    "name": "South Carolina"
  },
  "serviceType": [
    "Tree Removal",
    "Emergency Storm Response",
    "Land Clearing",
    "Forestry Mulching"
  ],
  "priceRange": "$$"
};

const homeBreadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": site.url
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does tree removal cost in South Carolina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On average, homeowners pay between $385 and $2,000 for professional tree extraction. Small trees under 30 feet sit at the lower end, while massive 80-foot specimens requiring crane assistance sit at the top."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a permit to remove a tree in South Carolina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Permit requirements are governed locally by individual municipalities. Cities like Charleston and Mount Pleasant protect 'Grand Trees' (24+ inches DBH) and require an official arborist report before removal approval."
      }
    },
    {
      "@type": "Question",
      "name": "What should I do when a tree falls on my house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Immediately evacuate and call emergency services if utility lines are compromised. Take extensive photos of the structural impact and contact an emergency tree service provider to stabilize the timber and tarp the roof."
      }
    },
    {
      "@type": "Question",
      "name": "Does homeowners insurance cover tree removal in South Carolina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "According to the South Carolina Department of Insurance, policies generally cover removal costs if the tree falls due to a covered peril (like windstorms) and impacts a covered structure. Trees fallen harmlessly in the yard are typically classified as maintenance and not covered."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a 24-hour emergency tree removal service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our emergency crews operate continuously day and night, 365 days a year across South Carolina. We maintain fully equipped crews on standby for high-liability situations like trees blocking roads or impacting roofs."
      }
    },
    {
      "@type": "Question",
      "name": "Can you remove a tree close to my house safely?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. We use high-capacity mobile cranes and specialized rigging systems to segment and hoist heavy timber away from your roofline without dropping debris onto your lawn or hardscapes."
      }
    }
  ]
};
---

<BaseLayout 
  title="Tree Removal in South Carolina | South Carolina Tree Removal Experts"
  description="Need professional tree removal in South Carolina? South Carolina Tree Removal Experts has 38 years of experience. Licensed & insured. Free quotes. Call (888) 643-4199."
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(homeBreadcrumbs)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header slot="header" />
  
  <!-- ============================================ -->
  <!-- SECTION 1: HERO -->
  <!-- ============================================ -->
  <section class="relative min-h-[95vh] flex items-center pt-24 pb-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/40 z-10"></div>
      <img src="/images/optimized/hero-home.webp" alt="Professional Tree Removal Crew at Work in South Carolina" class="w-full h-full object-cover" />
    </div>

    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-20">
      <div class="max-w-2xl text-white">
        <div class="inline-flex items-center gap-2 bg-primary-600/30 backdrop-blur-md border border-primary-500/40 px-4 py-2 rounded-full mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="text-sm font-semibold tracking-wide uppercase">Fully Licensed & Insured SC Experts</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-bold font-heading mb-8 leading-[1.1]">
          South Carolina's Most Trusted <span class="text-primary-400">Tree Removal Experts</span> &mdash; Serving the Entire State for 38 Years
        </h1>
        <p class="text-lg md:text-xl text-neutral-200 mb-6 leading-relaxed max-w-xl">
          Licensed. Insured. Local. Available 24/7 for Emergency Tree Removal Across All of South Carolina.
        </p>
        <div class="text-base text-neutral-300 mb-10 leading-relaxed max-w-xl space-y-4">
          <p>South Carolina Tree Removal Experts is the Palmetto State's most experienced tree removal company &mdash; trusted by homeowners, property managers, and businesses for over 38 years.</p>
          <p>Whether you have a dead tree threatening your roof, storm damage that cannot wait, or land that needs clearing for construction, we have the heavy equipment (cranes, bucket trucks, forestry mulchers) and the local expertise to handle it safely and affordably.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="tel:(888) 643-4199" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1 text-center">
            Call Now
          </a>
          <a href="/contact/" class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-md font-bold text-lg transition-all text-center flex items-center justify-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Get a Free Estimate
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 2: TRUST BAR -->
  <!-- ============================================ -->
  <section class="relative z-30 -mt-8 mb-0">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="bg-white rounded-3xl shadow-2xl border border-neutral-100 p-8 md:p-10">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 md:gap-8">
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <ShieldCheck size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Licensed &amp; Insured</span>
            <span class="text-xs text-neutral-500">Fully licensed and insured for every job</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <span class="font-bold text-neutral-900 text-sm">24/7 Emergency Service</span>
            <span class="text-xs text-neutral-500">Day or night &mdash; we respond fast across SC</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <ClipboardCheck size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Free Estimates</span>
            <span class="text-xs text-neutral-500">No obligation &mdash; get your quote today</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <MapPin size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Locally Operated in SC</span>
            <span class="text-xs text-neutral-500">South Carolina owned and operated</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <HardHat size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Residential &amp; Commercial</span>
            <span class="text-xs text-neutral-500">We serve homeowners and businesses</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 3: EMERGENCY BANNER -->
  <!-- ============================================ -->
  <section class="py-24 bg-primary-600 relative overflow-hidden">
    <div class="absolute inset-0 bg-neutral-900/10 z-0"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-500 rounded-full blur-3xl opacity-30 -translate-y-1/2 translate-x-1/2"></div>
    <div class="container mx-auto px-4 md:px-8 max-w-4xl relative z-10 text-center">
      <h2 class="text-3xl md:text-5xl font-bold font-heading text-white mb-8 leading-tight">
        24/7 Emergency Tree Removal in South Carolina
      </h2>
      <p class="text-lg text-primary-50 mb-6 max-w-2xl mx-auto leading-relaxed">
        When severe weather strikes, our high-urgency <strong class="text-white">storm and fallen tree response</strong> teams are on standby for immediate mobilization. Specializing in complex <strong class="text-white">tree-on-house or car</strong> extractions, we deploy crane-assisted rigging for <strong class="text-white">same-day service</strong> with a guaranteed fast response.
      </p>
      <p class="text-sm text-primary-200 mb-10 max-w-2xl mx-auto leading-relaxed">
        Our teams coordinate directly with <a href="https://www.scemd.org/" target="_blank" rel="noopener" class="underline hover:text-white transition-colors">local South Carolina emergency protocols</a> to ensure rapid, compliant site stabilization.
      </p>
      <a href="tel:(888) 643-4199" class="inline-flex items-center gap-3 bg-white text-primary-700 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-50 transition-all shadow-xl">
        <Phone size={24} />
        Call Emergency Line Now
      </a>
    </div>
  </section>

  
  <!-- ============================================ -->
  <!-- SECTION 4: INTRO -->
  <!-- ============================================ -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Professional Tree Removal, Emergency Response & Land Clearing Services</h2>
        <p class="text-lg text-neutral-600 leading-relaxed text-left">
          At South Carolina Tree Removal Experts, we do more than just cut down trees. We provide comprehensive arboricultural services designed to protect your property, enhance your landscape, and mitigate extreme weather risks. With nearly four decades of hands-on experience across the state of South Carolina, our certified crews bring unparalleled skill to every job site.
        </p>
      </div>
      <div class="bg-neutral-50 rounded-2xl p-8 border border-neutral-100 shadow-sm">
        <ul class="space-y-4 text-neutral-700">
          <li class="flex gap-4">
            <span class="text-primary-600 mt-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
            <div><strong>What We Do:</strong> Tree removal, emergency storm response, land clearing, brush clearing, debris removal, and forestry mulching.</div>
          </li>
          <li class="flex gap-4">
            <span class="text-primary-600 mt-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
            <div><strong>Who We Serve:</strong> Residential homeowners, commercial property developers, municipal governments, and HOAs.</div>
          </li>
          <li class="flex gap-4">
            <span class="text-primary-600 mt-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
            <div><strong>Where We Go:</strong> From Charleston to Greenville, Myrtle Beach to Columbia — we cover every county in SC.</div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 5: SERVICES -->
  <!-- ============================================ -->
  <section class="py-24 bg-neutral-50">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Our Services at a Glance</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- 3A -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-100 hover:shadow-md transition-shadow">
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">Tree Removal Services</h3>
          <ul class="space-y-3 text-neutral-600 mb-6">
            <li><strong>Dead & Diseased Tree Extraction:</strong> Preventing rot and preventing collapse.</li>
            <li><strong>Hazardous Tree Removal:</strong> Eliminating structural threats overhanging roofs, power lines, or driveways.</li>
            <li><strong>Crane-Assisted Removal:</strong> Utilizing zero-impact cranes to hoist massive timber safely over obstacles.</li>
          </ul>
          <a href="/services/tree-removal/" class="text-primary-600 font-bold hover:text-primary-700">Learn More &rarr;</a>
        </div>
        <!-- 3B -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-100 hover:shadow-md transition-shadow">
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">Emergency Tree Removal</h3>
          <ul class="space-y-3 text-neutral-600 mb-6">
            <li><strong>24/7 Storm Response:</strong> Immediate mobilization after hurricanes, tornadoes, and severe ice storms.</li>
            <li><strong>Tree on House / Car Removal:</strong> Delicate, high-tension rigging to extract fallen timber without causing further structural damage.</li>
            <li><strong>Fallen Tree Road Clearing:</strong> Rapid stabilization to restore access to your property.</li>
          </ul>
          <a href="/services/emergency-tree-removal/" class="text-primary-600 font-bold hover:text-primary-700">Learn More &rarr;</a>
        </div>
        <!-- 3C -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-100 hover:shadow-md transition-shadow">
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">Land & Lot Clearing</h3>
          <ul class="space-y-3 text-neutral-600 mb-6">
            <li><strong>New Construction Site Prep:</strong> Full-scale timber removal and grading preparation for residential or commercial builds.</li>
            <li><strong>Forestry Mulching & Brush Clearing:</strong> Eco-friendly underbrush management to reclaim overgrown acres.</li>
            <li><strong>Right-of-Way Clearing:</strong> Establishing access paths for utilities or private roads.</li>
          </ul>
          <a href="/services/land-clearing/" class="text-primary-600 font-bold hover:text-primary-700">Learn More &rarr;</a>
        </div>
        <!-- 3D -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-100 hover:shadow-md transition-shadow">
          <h3 class="text-2xl font-bold text-neutral-900 mb-4">Forestry Mulching</h3>
          <ul class="space-y-3 text-neutral-600 mb-6">
            <li><strong>HOA & Multi-Family Management:</strong> Ongoing canopy maintenance for large residential communities.</li>
            <li><strong>Municipal Forestry:</strong> Partnering with local SC governments for park maintenance and public right-of-way hazard removal.</li>
            <li><strong>Golf Course & Resort Tree Care:</strong> Aesthetic and safety-focused clearing for high-end properties.</li>
          </ul>
          <a href="/services/forestry-mulching/" class="text-primary-600 font-bold hover:text-primary-700">Learn More &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 6: WHY CHOOSE US -->
  <!-- ============================================ -->
  <section class="py-24 bg-white relative">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Why Choose South Carolina Tree Removal Experts?</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="bg-primary-50 p-3 rounded-lg text-primary-600 h-fit"><Award size={24} /></div>
              <div>
                <h4 class="font-bold text-xl text-neutral-900">38 Years of Battle-Tested Experience</h4>
                <p class="text-neutral-600">We survived Hugo, Matthew, and Ian. We have seen every type of structural failure and know exactly how to handle complex SC tree mechanics.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="bg-primary-50 p-3 rounded-lg text-primary-600 h-fit"><ShieldCheck size={24} /></div>
              <div>
                <h4 class="font-bold text-xl text-neutral-900">Ironclad Licensing & Insurance</h4>
                <p class="text-neutral-600">Tree removal is dangerous. Do not risk a lawsuit with a "guy and a chainsaw." We carry comprehensive General Liability and Workers' Compensation tailored specifically for high-risk logging and arboriculture.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="bg-primary-50 p-3 rounded-lg text-primary-600 h-fit"><HardHat size={24} /></div>
              <div>
                <h4 class="font-bold text-xl text-neutral-900">Heavy Metal Capabilities</h4>
                <p class="text-neutral-600">We own our fleets. From 100-ton mobile cranes to specialized tracked lifts that fit through 36-inch gates, we have the specialized gear to do the job faster, safer, and cheaper.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="bg-primary-50 p-3 rounded-lg text-primary-600 h-fit"><MapPin size={24} /></div>
              <div>
                <h4 class="font-bold text-xl text-neutral-900">Local Knowledge</h4>
                <p class="text-neutral-600">We understand SC's protected "Grand Tree" ordinances and can help navigate local municipal permitting processes.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative">
          <img src="/images/optimized/hero-home.webp" alt="Why Choose Us" class="rounded-3xl shadow-2xl w-full object-cover aspect-[4/5]" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 7: BLOG INSIGHTS -->
  <!-- ============================================ -->
  {latestPosts.length > 0 && (
    <section class="py-24 bg-neutral-50">
      <div class="container mx-auto px-4 md:px-8 max-w-7xl">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14">
          <div class="max-w-3xl">
            <p class="text-sm font-bold uppercase tracking-wider text-primary-600 mb-3">Tree Care Insights</p>
            <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-5">Latest Tree Removal Advice</h2>
            <p class="text-lg text-neutral-600 leading-relaxed">
              Practical guidance on hazardous trees, emergency storm response, land clearing, and property safety from South Carolina tree service professionals.
            </p>
          </div>
          <a href="/blog/" class="inline-flex items-center justify-center gap-2 rounded-md bg-primary-600 px-7 py-4 font-bold text-white shadow-lg transition-all hover:bg-primary-700">
            View More Articles
            <ArrowRight size={18} />
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {latestPosts.map(post => (
            <a href={`/blog/${getPostSlug(post)}/`} class="group flex h-full flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:border-primary-200 hover:shadow-xl">
              {post.data.featuredImage ? (
                <div class="h-52 overflow-hidden bg-neutral-100">
                  <img src={post.data.featuredImage} alt={post.data.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                </div>
              ) : (
                <div class="h-52 bg-neutral-900 flex items-center justify-center p-6 text-center">
                  <span class="text-xl font-bold font-heading text-white/70">{post.data.title}</span>
                </div>
              )}
              <div class="flex flex-1 flex-col p-7">
                <div class="mb-4 flex flex-wrap items-center gap-3 text-xs font-bold uppercase tracking-wider text-neutral-500">
                  {post.data.category && <span class="rounded-full bg-primary-50 px-3 py-1 text-primary-700">{post.data.category}</span>}
                  <span class="inline-flex items-center gap-1">
                    <Calendar size={14} />
                    {post.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
                <h3 class="mb-4 text-2xl font-bold font-heading leading-tight text-neutral-900 transition-colors group-hover:text-primary-600">{post.data.title}</h3>
                <p class="mb-6 line-clamp-3 flex-1 text-neutral-600 leading-relaxed">{getPostExcerpt(post)}</p>
                <span class="mt-auto inline-flex items-center gap-2 font-bold text-primary-600">
                  Read Article
                  <ArrowRight size={18} class="transition-transform group-hover:translate-x-1" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================ -->
  <!-- SECTION 8: HOW IT WORKS -->
  <!-- ============================================ -->
  <section class="py-24 bg-neutral-900 text-white relative">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-heading mb-6">Our 6-Step Process</h2>
        <p class="text-lg text-neutral-400">Streamlined for your convenience and safety.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-neutral-800 p-8 rounded-2xl border border-neutral-700">
          <div class="text-primary-500 font-bold text-5xl mb-4">1</div>
          <h4 class="text-xl font-bold mb-3">You Call or Click</h4>
