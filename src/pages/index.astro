---
import { site } from '../data/site';
import { Phone, Star, ShieldCheck, HardHat, MapPin, ClipboardCheck, Leaf, ChevronDown, Award, Users, AlertTriangle } from 'lucide-react';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { services } from '../data/services';
import { locations } from '../data/locations';
import ContactForm from '../components/ContactForm.astro';

const featuredServices = services.filter(s => s.slug !== 'stump-grinding');
const topLocations = locations.slice(0, 6);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${site.url}/#organization`,
  "name": site.name,
  "legalName": site.legalName,
  "url": site.url,
  "telephone": site.phone,
  "email": site.email,
  "logo": `${site.url}/images/logo.png`,
  "image": `${site.url}/images/optimized/og-image.webp`,
  "hasMap": `${site.url}/contact/`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": site.address.street,
    "addressLocality": site.address.city,
    "addressRegion": site.address.state,
    "postalCode": site.address.zip,
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "State",
    "name": "South Carolina"
  },
  "serviceType": [
    "Tree Removal",
    "Emergency Storm Response",
    "Land Clearing",
    "Commercial Forestry"
  ],
  "priceRange": "$$"
};

const homeBreadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": site.url
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does tree removal cost in South Carolina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On average, homeowners pay between $385 and $2,000 for professional tree extraction. Small trees under 30 feet sit at the lower end, while massive 80-foot specimens requiring crane assistance sit at the top."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a permit to remove a tree in South Carolina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Permit requirements are governed locally by individual municipalities. Cities like Charleston and Mount Pleasant protect 'Grand Trees' (24+ inches DBH) and require an official arborist report before removal approval."
      }
    },
    {
      "@type": "Question",
      "name": "What should I do when a tree falls on my house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Immediately evacuate and call emergency services if utility lines are compromised. Take extensive photos of the structural impact and contact an emergency tree service provider to stabilize the timber and tarp the roof."
      }
    },
    {
      "@type": "Question",
      "name": "Does homeowners insurance cover tree removal in South Carolina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "According to the South Carolina Department of Insurance, policies generally cover removal costs if the tree falls due to a covered peril (like windstorms) and impacts a covered structure. Trees fallen harmlessly in the yard are typically classified as maintenance and not covered."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a 24-hour emergency tree removal service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our emergency crews operate continuously day and night, 365 days a year across South Carolina. We maintain fully equipped crews on standby for high-liability situations like trees blocking roads or impacting roofs."
      }
    },
    {
      "@type": "Question",
      "name": "Can you remove a tree close to my house safely?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. We use high-capacity mobile cranes and specialized rigging systems to segment and hoist heavy timber away from your roofline without dropping debris onto your lawn or hardscapes."
      }
    }
  ]
};
---

<BaseLayout 
  title="Tree Removal South Carolina | 24/7 Storm Response & Free Estimates"
  description="South Carolina's trusted tree removal experts. 24/7 emergency storm response, land clearing & commercial services. Licensed & insured. Call for a free estimate."
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(homeBreadcrumbs)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header slot="header" />
  
  <!-- ============================================ -->
  <!-- SECTION 1: HERO -->
  <!-- ============================================ -->
  <section class="relative min-h-[95vh] flex items-center pt-24 pb-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/40 z-10"></div>
      <img src="/images/optimized/hero-home.webp" alt="Professional Tree Removal Crew at Work in South Carolina" class="w-full h-full object-cover" />
    </div>

    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-20">
      <div class="max-w-2xl text-white">
        <div class="inline-flex items-center gap-2 bg-primary-600/30 backdrop-blur-md border border-primary-500/40 px-4 py-2 rounded-full mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="text-sm font-semibold tracking-wide uppercase">Fully Licensed & Insured SC Experts</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-bold font-heading mb-8 leading-[1.1]">
          Tree Removal <span class="text-primary-400">South Carolina</span>
        </h1>
        <p class="text-lg md:text-xl text-neutral-200 mb-6 leading-relaxed max-w-xl">
          South Carolina's Trusted Tree Removal Company &mdash; Available 24/7 for Emergency Tree Removal, Storm Damage &amp; More
        </p>
        <p class="text-base text-neutral-300 mb-10 leading-relaxed max-w-xl">
          Fully <strong class="text-white">licensed and insured</strong>, we deploy high-tension rigging and crane-assisted extraction to safely eliminate structural hazards from residential and commercial properties. Contact our local SC operators today for your <strong class="text-white">free estimate</strong>.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="tel:(888) 643-4199" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-all shadow-xl hover:shadow-2xl hover:-translate-y-1 text-center">
            Call Now
          </a>
          <a href="/contact/" class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-md font-bold text-lg transition-all text-center flex items-center justify-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Get a Free Estimate
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 2: TRUST BAR -->
  <!-- ============================================ -->
  <section class="relative z-30 -mt-8 mb-0">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="bg-white rounded-3xl shadow-2xl border border-neutral-100 p-8 md:p-10">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 md:gap-8">
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <ShieldCheck size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Licensed &amp; Insured</span>
            <span class="text-xs text-neutral-500">Fully licensed and insured for every job</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <span class="font-bold text-neutral-900 text-sm">24/7 Emergency Service</span>
            <span class="text-xs text-neutral-500">Day or night &mdash; we respond fast across SC</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <ClipboardCheck size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Free Estimates</span>
            <span class="text-xs text-neutral-500">No obligation &mdash; get your quote today</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <MapPin size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Locally Operated in SC</span>
            <span class="text-xs text-neutral-500">South Carolina owned and operated</span>
          </div>
          <div class="flex flex-col items-center text-center gap-3 p-4">
            <div class="bg-primary-50 p-4 rounded-2xl text-primary-600">
              <HardHat size={32} />
            </div>
            <span class="font-bold text-neutral-900 text-sm">Residential &amp; Commercial</span>
            <span class="text-xs text-neutral-500">We serve homeowners and businesses</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 3: EMERGENCY BANNER -->
  <!-- ============================================ -->
  <section class="py-24 bg-primary-600 relative overflow-hidden">
    <div class="absolute inset-0 bg-neutral-900/10 z-0"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-500 rounded-full blur-3xl opacity-30 -translate-y-1/2 translate-x-1/2"></div>
    <div class="container mx-auto px-4 md:px-8 max-w-4xl relative z-10 text-center">
      <h2 class="text-3xl md:text-5xl font-bold font-heading text-white mb-8 leading-tight">
        24/7 Emergency Tree Removal in South Carolina
      </h2>
      <p class="text-lg text-primary-50 mb-6 max-w-2xl mx-auto leading-relaxed">
        When severe weather strikes, our high-urgency <strong class="text-white">storm and fallen tree response</strong> teams are on standby for immediate mobilization. Specializing in complex <strong class="text-white">tree-on-house or car</strong> extractions, we deploy crane-assisted rigging for <strong class="text-white">same-day service</strong> with a guaranteed fast response.
      </p>
      <p class="text-sm text-primary-200 mb-10 max-w-2xl mx-auto leading-relaxed">
        Our teams coordinate directly with <a href="https://www.scemd.org/" target="_blank" rel="noopener" class="underline hover:text-white transition-colors">local South Carolina emergency protocols</a> to ensure rapid, compliant site stabilization.
      </p>
      <a href="tel:(888) 643-4199" class="inline-flex items-center gap-3 bg-white text-primary-700 px-10 py-5 rounded-md font-bold text-xl hover:bg-primary-50 transition-all shadow-xl">
        <Phone size={24} />
        Call Emergency Line Now
      </a>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 4: SERVICES OVERVIEW -->
  <!-- ============================================ -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Our Tree Removal Services in South Carolina</h2>
        <p class="text-lg text-neutral-600">From high-risk residential canopy management to large-scale commercial site preparation, our specialized crews deliver comprehensive arborist solutions tailored to South Carolina's unique geographic conditions.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Service 1: Tree Removal -->
        <a href="/services/residential-tree-removal/" class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-primary-500 hover:shadow-lg transition-all">
          <div class="bg-primary-600/10 w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all">
            <Leaf size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Residential Tree Removal</h3>
          <p class="text-neutral-600 text-sm leading-relaxed mb-4">Precision extraction of dead, diseased, or hazardous trees using advanced rigging and crane techniques. Safe removal from tight spaces near structures, power lines, and delicate landscaping.</p>
          <span class="text-primary-600 font-bold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">Learn More &rarr;</span>
        </a>

        <!-- Service 2: Emergency -->
        <a href="/services/emergency-storm-response/" class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-primary-500 hover:shadow-lg transition-all">
          <div class="bg-primary-600/10 w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Emergency Storm Response</h3>
          <p class="text-neutral-600 text-sm leading-relaxed mb-4">24/7 rapid deployment for fallen trees, storm damage, and hazardous limb failures. Tree-on-house and tree-on-car extraction with insurance documentation support.</p>
          <span class="text-primary-600 font-bold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">Learn More &rarr;</span>
        </a>

        <!-- Service 3: Land Clearing -->
        <a href="/services/land-clearing-grading/" class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-primary-500 hover:shadow-lg transition-all">
          <div class="bg-primary-600/10 w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all">
            <HardHat size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Land Clearing &amp; Grading</h3>
          <p class="text-neutral-600 text-sm leading-relaxed mb-4">Forestry mulching, brush clearing, and debris removal to transform overgrown acreage into clean, construction-ready parcels. Erosion control and site grading included.</p>
          <span class="text-primary-600 font-bold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">Learn More &rarr;</span>
        </a>

        <!-- Service 4: Commercial -->
        <a href="/services/commercial-forestry/" class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-primary-500 hover:shadow-lg transition-all">
          <div class="bg-primary-600/10 w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all">
            <Award size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Commercial Tree Services</h3>
          <p class="text-neutral-600 text-sm leading-relaxed mb-4">Scalable solutions for municipalities, HOAs, developers, and property managers. Bulk tree removal, construction site clearing, and right-of-way maintenance across South Carolina.</p>
          <span class="text-primary-600 font-bold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">Learn More &rarr;</span>
        </a>
      </div>

      <div class="text-center mt-12">
        <a href="/services/" class="inline-flex items-center gap-2 bg-neutral-900 text-white px-8 py-4 rounded-md font-bold hover:bg-neutral-800 transition-colors">
          View All Services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 5: WHY CHOOSE US -->
  <!-- ============================================ -->
  <section class="py-24 bg-neutral-50 border-t border-neutral-100">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Why South Carolina Trusts Us for Tree Removal</h2>
        <p class="text-lg text-neutral-600">When dealing with multi-ton structural hazards, there is no margin for amateur error. Our operation replaces guesswork with proven corporate capability, regulatory compliance, and localized expertise.</p>
      </div>

      <div class="text-center mb-8">
        <a href="/about/" class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-md font-bold text-lg transition-all shadow-lg hover:shadow-xl">
          Learn More About Us &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm hover:shadow-lg transition-shadow">
          <div class="bg-primary-50 w-14 h-14 rounded-xl flex items-center justify-center text-primary-600 mb-6">
            <ShieldCheck size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Licensed &amp; Fully Insured</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">Comprehensive general liability and workers' compensation policies shift all operational risk away from the homeowner and onto our firm.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm hover:shadow-lg transition-shadow">
          <div class="bg-primary-50 w-14 h-14 rounded-xl flex items-center justify-center text-primary-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">24/7 Emergency Availability</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">Our high-priority, rapid-response dispatch units remain continuously active day and night, 365 days a year across South Carolina.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm hover:shadow-lg transition-shadow">
          <div class="bg-primary-50 w-14 h-14 rounded-xl flex items-center justify-center text-primary-600 mb-6">
            <ClipboardCheck size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Free Estimates</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">Transparent, line-item pricing with zero financial obligation. Our arborist evaluations ensure you understand requirements and exact costs before work begins.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm hover:shadow-lg transition-shadow">
          <div class="bg-primary-50 w-14 h-14 rounded-xl flex items-center justify-center text-primary-600 mb-6">
            <Users size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Experienced Local SC Crews</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">Native operators with intimate understanding of South Carolina's soil structures, coastal weather patterns, and municipal tree preservation ordinances.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm hover:shadow-lg transition-shadow">
          <div class="bg-primary-50 w-14 h-14 rounded-xl flex items-center justify-center text-primary-600 mb-6">
            <HardHat size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Residential &amp; Commercial Services</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">Our fleet ranges from low-impact residential mini-loaders to massive commercial cranes, scaling seamlessly to any project size or technical constraint.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm hover:shadow-lg transition-shadow">
          <div class="bg-primary-50 w-14 h-14 rounded-xl flex items-center justify-center text-primary-600 mb-6">
            <Leaf size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Complete Cleanup Included</h3>
          <p class="text-neutral-600 text-sm leading-relaxed">Every removal includes exhaustive site remediation. We buck the logs, run limbs through the chipper, rake the turf, and blow down your hardscapes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SECTION 6: TREE TYPES WE REMOVE -->
  <!-- ============================================ -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 md:px-8 max-w-7xl">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-4xl md:text-5xl font-bold font-heading text-neutral-900 mb-6">Trees We Remove Across South Carolina</h2>
        <p class="text-lg text-neutral-600">South Carolina's diverse ecosystems support a wide array of native and introduced tree species. Severe thunderstorms and seasonal hurricane fronts can easily compromise their structural integrity. Our teams are experienced in handling the unique wood densities and failures characteristic of regional flora.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Pine -->
        <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-primary-500 hover:shadow-lg transition-all">
          <div class="bg-primary-600/10 w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all">
            <Leaf size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Pine Tree Removal</h3>
          <p class="text-neutral-600 text-sm leading-relaxed mb-3">South Carolina features massive populations of <strong>Loblolly Pine</strong> (<em>Pinus taeda</em>) and <strong>Longleaf Pine</strong> (<em>Pinus palustris</em>). Rapidly growing pines have softer wood fibers highly susceptible to snapping under windthrow forces.</p>
          <p class="text-neutral-500 text-sm leading-relaxed">Aging pines are prone to destructive Southern Pine Beetle infestations that hollow out the trunk. Our crews use precise directional felling or structured climbing to dismantle these hazards safely.</p>
        </div>

        <!-- Oak -->
        <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-primary-500 hover:shadow-lg transition-all">
          <div class="bg-primary-600/10 w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all">
            <Award size={28} />
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Oak Tree Removal</h3>
          <p class="text-neutral-600 text-sm leading-relaxed mb-3">The majestic <strong>Southern Live Oak</strong> (<em>Quercus virginiana</em>) and dense <strong>Water Oak</strong> (<em>Quercus nigra</em>) are structural staples across the Carolinas. Mature oaks often suffer from hidden heartwood decay and internal root rot.</p>
          <p class="text-neutral-500 text-sm leading-relaxed">Due to the immense weight of oak timber, a single failing branch can cause catastrophic damage. We deploy crane-assisted extraction to lift and clear heavy oak limbs safely.</p>
        </div>

        <!-- Palmetto -->
        <div class="group bg-neutral-50 rounded-2xl p-8 border border-neutral-100 hover:border-primary-500 hover:shadow-lg transition-all">
          <div class="bg-primary-600/10 w-14 h-14 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 14V2"/><path d="M10 10V2"/><path d="M3 7V2"/><path d="m7 22 3-8 4 4 3-6"/></svg>
          </div>
          <h3 class="font-bold text-xl text-neutral-900 mb-3">Palmetto Tree Removal</h3>
