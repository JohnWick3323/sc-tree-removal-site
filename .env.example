# Google Maps Embed API Key
# Used for map embeds on contact page and location pages
# Get yours at: https://console.cloud.google.com/apis/credentials
PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_embed_api_key_here

# Resend API Key (server-side only — do NOT prefix with PUBLIC_)
# Used by Cloudflare Function: functions/api/send-email.js
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
